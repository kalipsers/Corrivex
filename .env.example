# Copy to .env and edit. Used by docker-compose for the Linux deployment.

# MariaDB credentials (compose creates the DB on first run)
DB_NAME=corrivex
DB_USER=corrivex
DB_PASS=change-me-32-random-chars
DB_ROOT_PASS=change-me-32-random-chars

# Optional shared secret all agents must send. Leave blank to disable.
API_SECRET=

# To enable HTTPS, mount the cert/key into the container and set:
# TLS_CERT=/etc/corrivex/server.pem
# TLS_KEY=/etc/corrivex/server.key

# Timezone applied to BOTH the MariaDB and Corrivex-server containers so
# CURRENT_TIMESTAMP and Go's time.Now() agree. Use IANA names, e.g.
#   Europe/Bratislava, Europe/Prague, America/New_York, Asia/Tokyo
# Defaults to UTC when unset.
TZ=UTC

# CVE scanning — the server periodically queries OSV + NVD + CISA KEV for
# every installed (package, version) pair reported by agents. Set
# CVE_SCAN_ENABLED=false to disable (air-gapped / restricted-egress
# deployments). NVD_API_KEY is optional — request one free at
# https://nvd.nist.gov/developers/request-an-api-key to raise the rate
# limit from 5 to 50 requests per 30 seconds.
CVE_SCAN_ENABLED=true
NVD_API_KEY=
