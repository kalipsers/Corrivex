# Copy to .env and edit. Used by docker-compose for the Linux deployment.

# MariaDB credentials (compose creates the DB on first run)
DB_NAME=corrivex
DB_USER=corrivex
DB_PASS=change-me-32-random-chars
DB_ROOT_PASS=change-me-32-random-chars

# Optional shared secret all agents must send. Leave blank to disable.
API_SECRET=

# To enable HTTPS, mount the cert/key into the container and set:
# TLS_CERT=/etc/corrivex/server.pem
# TLS_KEY=/etc/corrivex/server.key
