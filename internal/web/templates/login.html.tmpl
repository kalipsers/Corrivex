<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Corrivex — Sign in</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --c-primary:#0F172A; --c-secondary:#334155; --c-cta:#0369A1; --c-cta-hover:#075985;
  --c-bg:#F8FAFC; --c-surface:#FFFFFF; --c-text:#020617; --c-text-2:#334155;
  --c-muted:#64748B; --c-border:#E2E8F0; --c-border-2:#CBD5E1;
  --c-success:#047857; --c-success-bg:#ECFDF5; --c-danger:#B91C1C; --c-danger-bg:#FEF2F2;
  --r-sm:6px; --r-md:8px; --r-lg:12px; --r-xl:16px;
  --shadow-lg:0 20px 40px -12px rgba(15,23,42,.18), 0 8px 16px -8px rgba(15,23,42,.08);
  --ease:cubic-bezier(.4,0,.2,1); --d-fast:150ms;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
@media(prefers-reduced-motion:reduce){*{transition:none!important;animation:none!important}}
body{background:var(--c-bg);color:var(--c-text);font-family:'Plus Jakarta Sans',system-ui,sans-serif;font-size:14px;line-height:1.55;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;-webkit-font-smoothing:antialiased}
:focus-visible{outline:2px solid var(--c-cta);outline-offset:2px;border-radius:var(--r-sm)}
.card{width:100%;max-width:420px;background:var(--c-surface);border:1px solid var(--c-border);border-radius:var(--r-xl);box-shadow:var(--shadow-lg);overflow:hidden}
.card-hd{padding:28px 28px 0}
.card-bd{padding:20px 28px 28px}
.brand{display:flex;align-items:center;gap:12px;margin-bottom:20px}
.brand-mark{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,var(--c-primary),var(--c-secondary));display:inline-flex;align-items:center;justify-content:center;color:#fff}
.brand-name{font-size:17px;font-weight:700;letter-spacing:-.015em;color:var(--c-primary)}
.brand-tag{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--c-muted);padding:2px 8px;border:1px solid var(--c-border);border-radius:999px;background:var(--c-bg);margin-left:auto}
h1{font-size:22px;font-weight:700;letter-spacing:-.015em;color:var(--c-primary);margin-bottom:6px}
.sub{color:var(--c-muted);font-size:13px;margin-bottom:18px}
.field{display:flex;flex-direction:column;gap:6px}
.field+.field{margin-top:14px}
.field label{font-size:12px;font-weight:600;color:var(--c-text-2)}
.field input{font:inherit;font-size:14px;padding:10px 12px;border:1px solid var(--c-border-2);border-radius:var(--r-md);background:var(--c-surface);color:var(--c-text);transition:border-color var(--d-fast) var(--ease),box-shadow var(--d-fast) var(--ease)}
.field input:focus{border-color:var(--c-cta);box-shadow:0 0 0 3px rgba(3,105,161,.15);outline:none}
.hint{font-size:11px;color:var(--c-muted)}
.btn{appearance:none;cursor:pointer;font:inherit;font-size:14px;font-weight:500;padding:10px 16px;border-radius:var(--r-md);border:1px solid var(--c-border-2);background:var(--c-surface);color:var(--c-text);display:inline-flex;align-items:center;justify-content:center;gap:8px;transition:background var(--d-fast) var(--ease),border-color var(--d-fast) var(--ease),color var(--d-fast) var(--ease)}
.btn-primary{background:var(--c-cta);border-color:var(--c-cta);color:#fff}
.btn-primary:hover{background:var(--c-cta-hover);border-color:var(--c-cta-hover)}
.btn-block{width:100%}
.btn:disabled{opacity:.55;cursor:not-allowed}
.banner{padding:10px 14px;border-radius:var(--r-md);font-size:13px;margin-bottom:14px;border:1px solid var(--c-border);display:flex;align-items:flex-start;gap:10px}
.banner.is-err{background:var(--c-danger-bg);border-color:#FECACA;color:var(--c-danger)}
.banner.is-info{background:#EFF6FF;border-color:#BFDBFE;color:var(--c-cta)}
.banner svg{width:16px;height:16px;margin-top:2px;flex-shrink:0}
.trust{margin-top:16px;display:flex;gap:8px;justify-content:center;color:var(--c-muted);font-size:11px}
.trust .chip{display:inline-flex;align-items:center;gap:6px;padding:3px 10px;background:var(--c-bg);border:1px solid var(--c-border);border-radius:999px}
.trust .chip svg{width:12px;height:12px}
</style>
</head>
<body>
<main class="card" role="main">
  <div class="card-hd">
    <div class="brand">
      <span class="brand-mark" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/></svg>
      </span>
      <span class="brand-name">Corrivex</span>
      <span class="brand-tag">Enterprise</span>
    </div>
  </div>
  <div class="card-bd">
    <div id="banner" class="banner is-info" style="display:none" role="alert"></div>

    <!-- Login form -->
    <form id="login-form" autocomplete="on">
      <h1>Sign in</h1>
      <div class="sub">Authorized personnel only. All actions are logged.</div>
      <div class="field">
        <label for="username">Username</label>
        <input type="text" id="username" name="username" autocomplete="username" required>
      </div>
      <div class="field">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" autocomplete="current-password" required>
      </div>
      <div class="field" id="totp-field" style="display:none">
        <label for="totp">Authenticator code</label>
        <input type="text" id="totp" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" autocomplete="one-time-code" placeholder="000000">
        <div class="hint">Enter the 6-digit code from your authenticator app.</div>
      </div>
      <div style="margin-top:18px">
        <button class="btn btn-primary btn-block" type="submit" id="login-btn">Sign in</button>
      </div>
    </form>

    <!-- Setup form (first admin) -->
    <form id="setup-form" autocomplete="off" style="display:none">
      <h1>Create first admin</h1>
      <div class="sub">No accounts exist yet. Create the first administrator to continue.</div>
      <div class="field">
        <label for="s-username">Admin username</label>
        <input type="text" id="s-username" required>
      </div>
      <div class="field">
        <label for="s-password">Password</label>
        <input type="password" id="s-password" minlength="8" required>
        <div class="hint">Minimum 8 characters. You can enable 2FA after signing in.</div>
      </div>
      <div style="margin-top:18px">
        <button class="btn btn-primary btn-block" type="submit" id="setup-btn">Create admin &amp; sign in</button>
      </div>
    </form>

    <div class="trust">
      <span class="chip"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>HttpOnly session cookie</span>
      <span class="chip">RFC 6238 TOTP</span>
    </div>
  </div>
</main>
<script>
const API = '/api/';

function showBanner(msg, kind) {
  const b = document.getElementById('banner');
  b.className = 'banner is-' + (kind || 'info');
  b.textContent = msg;
  b.style.display = 'flex';
}
function hideBanner() { document.getElementById('banner').style.display = 'none'; }

async function loadState() {
  try {
    const res = await fetch(API + '?action=auth_state', { credentials: 'same-origin' });
    const j = await res.json();
    if (j.user) { location.replace('/'); return; }
    if (!j.users_exist) {
      document.getElementById('login-form').style.display = 'none';
      document.getElementById('setup-form').style.display = '';
    }
  } catch (e) { /* fall through to login form */ }
}

document.getElementById('login-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  hideBanner();
  const btn = document.getElementById('login-btn');
  btn.disabled = true; btn.textContent = 'Signing in…';
  const payload = {
    username: document.getElementById('username').value.trim(),
    password: document.getElementById('password').value,
    totp_code: document.getElementById('totp').value.trim(),
  };
  try {
    const res = await fetch(API + '?action=login', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload), credentials: 'same-origin',
    });
    const j = await res.json();
    if (j.totp_required) {
      document.getElementById('totp-field').style.display = '';
      document.getElementById('totp').focus();
      showBanner('Enter the 6-digit code from your authenticator app.', 'info');
      return;
    }
    if (!res.ok) throw new Error(j.error || 'HTTP ' + res.status);
    location.replace('/');
  } catch (err) {
    showBanner(err.message, 'err');
  } finally {
    btn.disabled = false; btn.textContent = 'Sign in';
  }
});

document.getElementById('setup-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  hideBanner();
  const btn = document.getElementById('setup-btn');
  btn.disabled = true; btn.textContent = 'Creating…';
  const payload = {
    username: document.getElementById('s-username').value.trim(),
    password: document.getElementById('s-password').value,
  };
  try {
    const res = await fetch(API + '?action=setup_first_admin', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload), credentials: 'same-origin',
    });
    const j = await res.json();
    if (!res.ok) throw new Error(j.error || 'HTTP ' + res.status);
    location.replace('/');
  } catch (err) {
    showBanner(err.message, 'err');
  } finally {
    btn.disabled = false; btn.textContent = 'Create admin & sign in';
  }
});

loadState();
</script>
</body>
</html>
