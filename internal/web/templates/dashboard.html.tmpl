        <div>
          <h2 class="h2">Enroll a Windows device</h2>
          <div class="sub" style="color:var(--c-muted);font-size:12px;margin-top:4px">Run this command as an administrator on any Windows endpoint whose domain is in the allow list.</div>
        </div>
      </div>
      <div class="card-bd">
        <div class="cmd-block" id="bootstrap-cmd">{{.BootstrapCmd}}</div>
        <div style="margin-top:10px;display:flex;gap:10px;align-items:center">
          <button class="btn btn-dark" id="copy-bootstrap-btn">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
            Copy command
          </button>
          <span class="chip ok" style="gap:6px"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:12px;height:12px"><rect width="18" height="11" x="3" y="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>Domain allow-listed</span>
          <span class="chip info"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:12px;height:12px"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/></svg>Signed binary from {{.APIUrl}}</span>
        </div>

        <div class="section" style="margin-top:24px">
          <div class="section-hd"><div class="section-title">What this command does</div></div>
          <ul style="list-style:none;padding:0;display:grid;gap:8px">
            <li style="display:flex;gap:10px;align-items:flex-start"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--c-cta)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;flex-shrink:0;margin-top:2px"><polyline points="20 6 9 17 4 12"/></svg>Downloads <span class="mono">corrivex-agent.exe</span> to <span class="mono">C:\ProgramData\Corrivex</span>.</li>
            <li style="display:flex;gap:10px;align-items:flex-start"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--c-cta)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;flex-shrink:0;margin-top:2px"><polyline points="20 6 9 17 4 12"/></svg>Registers a Windows Service running as LocalSystem.</li>
            <li style="display:flex;gap:10px;align-items:flex-start"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--c-cta)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;flex-shrink:0;margin-top:2px"><polyline points="20 6 9 17 4 12"/></svg>Polls this server every <strong>{{.Settings.check_interval_minutes}} min</strong> and performs a full winget scan every <strong>{{.Settings.full_scan_interval_hours}} h</strong>.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</main>

