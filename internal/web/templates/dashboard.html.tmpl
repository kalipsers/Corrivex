<div class="toast-stack" id="toast-stack" aria-live="polite" aria-atomic="true"></div>

<script>
const API = "{{.APIUrl}}";
const CURRENT_USER = { username: "{{.CurrentUser.username}}", role: "{{.CurrentUser.role}}", totp_enabled: {{if .CurrentUser.totp_enabled}}true{{else}}false{{end}} };
if (CURRENT_USER.role === 'admin') document.body.classList.add('is-admin');

// ---- Tabs -----------------------------------------------------------------
document.querySelectorAll('.tab').forEach(t => {
  t.addEventListener('click', () => {
    document.querySelectorAll('.tab').forEach(x => { x.classList.remove('is-active'); x.setAttribute('aria-selected','false'); });
    document.querySelectorAll('.tab-panel').forEach(x => x.classList.remove('is-active'));
    t.classList.add('is-active'); t.setAttribute('aria-selected','true');
    document.getElementById('panel-' + t.dataset.tab).classList.add('is-active');
  });
});

// ---- Search / filter ------------------------------------------------------
const searchInput = document.getElementById('device-search');
const domainFilter = document.getElementById('domain-filter');
const stateFilter = document.getElementById('state-filter');
function applyFilter() {
  const q = (searchInput.value || '').toLowerCase();
  const d = (domainFilter.value || '').toLowerCase();
  const st = (stateFilter?.value || '');
  const now = Date.now();
  document.querySelectorAll('#device-table tbody tr[data-host]').forEach(tr => {
    const s = (tr.dataset.search || '').toLowerCase();
    const dd = (tr.dataset.domain || '').toLowerCase();
    const lastIso = tr.querySelector('td[data-since]')?.dataset?.since || '';
    const ageH = lastIso ? ((now - new Date(lastIso).getTime())/3600e3) : Infinity;
    const okQ = !q || s.includes(q);
    const okD = !d || dd === d;
    let okS = true;
    if (st === 'online') okS = ageH <= 24;
    else if (st === 'stale') okS = ageH > 72;
    else if (st === 'never') okS = !lastIso;
    tr.style.display = okQ && okD && okS ? '' : 'none';
  });
}
searchInput?.addEventListener('input', applyFilter);
domainFilter?.addEventListener('change', applyFilter);
stateFilter?.addEventListener('change', applyFilter);

// ---- Toasts --------------------------------------------------------------
const toastStack = document.getElementById('toast-stack');
const ICON_OK   = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
const ICON_ERR  = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>';
const ICON_WARN = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" x2="12" y1="9" y2="13"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg>';
function toast(msg, kind = 'ok') {
  const el = document.createElement('div');
  el.className = 'toast is-' + kind;
  el.innerHTML = (kind === 'err' ? ICON_ERR : kind === 'warn' ? ICON_WARN : ICON_OK) + '<div>' + escapeHTML(msg) + '</div>';
  toastStack.appendChild(el);
  setTimeout(() => { el.style.opacity = '0'; el.style.transform = 'translateY(4px)'; }, 3200);
  setTimeout(() => el.remove(), 3600);
}
function escapeHTML(s) { return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }

// ---- Modal ----------------------------------------------------------------
const modal = document.getElementById('device-modal');
function openModal() { modal.classList.add('is-open'); document.body.style.overflow = 'hidden'; }
function closeModal() {
  modal.classList.remove('is-open');
  document.body.style.overflow = '';
  // Clear the live log pane when the modal closes so the next open starts fresh.
  const log = document.getElementById('live-log');
  if (log) { log.innerHTML = ''; log.dataset.host = ''; }
  const wrap = document.getElementById('modal-log-wrap');
  if (wrap) wrap.classList.remove('is-live', 'is-pulse');
}

// Scroll the live-output pane into view and briefly highlight it so the user
// notices where live progress for a just-queued task will show up.
function popLogPane() {
  const wrap = document.getElementById('modal-log-wrap');
  const log = document.getElementById('live-log');
  if (!wrap || !log) return;
  wrap.classList.add('is-live');
  wrap.scrollIntoView({ behavior: 'smooth', block: 'end' });
  wrap.classList.remove('is-pulse');
  // re-trigger CSS transition/shadow
  void wrap.offsetWidth;
  wrap.classList.add('is-pulse');
  setTimeout(() => wrap.classList.remove('is-pulse'), 1200);
  log.scrollTop = log.scrollHeight;
}
modal.addEventListener('click', e => { if (e.target === modal || e.target.closest('[data-close]')) closeModal(); });
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

async function viewDevice(host) {
  document.getElementById('device-modal-title').textContent = host;
  document.getElementById('device-modal-sub').textContent = 'Loading…';
  document.getElementById('device-modal-body').textContent = 'Loading…';
  const rmBtn = document.getElementById('remove-device-btn');
  if (rmBtn) rmBtn.dataset.host = host;
  // Swap the persistent log pane to this host. If we're switching to a new
  // host, clear accumulated lines; if it's the same host (re-open), keep them.
  const log = document.getElementById('live-log');
  if (log && log.dataset.host !== host) {
    log.innerHTML = '';
    log.dataset.host = host;
  }
  openModal();
  try {
    const res = await fetch(API + '?host=' + encodeURIComponent(host));
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const pc = await res.json();
    renderDeviceModal(pc);
  } catch (e) {
    document.getElementById('device-modal-body').innerHTML = '<div class="banner is-err">Could not load device: ' + escapeHTML(e.message) + '</div>';
  }
}

function renderDeviceModal(pc) {
  const pkgs = safeParse(pc.last_packages) || [];
  const wu   = safeParse(pc.windows_updates) || [];
  const users = safeParse(pc.users) || [];
  const admins = safeParse(pc.local_admins) || [];
  document.getElementById('device-modal-sub').textContent =
    [pc.domain || '—', pc.os_version || '—', pc.last_seen ? ('seen ' + fmtAgo(pc.last_seen)) : 'never seen'].join('  ·  ');

  // Remember which sub-tab was active before this re-render so we don't
  // bounce back to "Overview" every time a 'pc' event arrives.
  const prevTab = document.querySelector('.modal-tab.is-active')?.dataset.modalTab || 'overview';

  let html = '';
  html += '<nav class="modal-tabs" role="tablist">';
  html += '<button class="modal-tab' + (prevTab==='overview'?' is-active':'') + '" data-modal-tab="overview">Overview</button>';
  html += '<button class="modal-tab' + (prevTab==='winget'?' is-active':'') + '" data-modal-tab="winget">Winget <span class="chip muted">' + pkgs.length + '</span></button>';
  html += '<button class="modal-tab' + (prevTab==='wu'?' is-active':'') + '" data-modal-tab="wu">Windows update <span class="chip muted">' + wu.length + '</span></button>';
  html += '</nav>';

  html += '<div class="modal-panel' + (prevTab==='overview'?' is-active':'') + '" data-modal-panel="overview">';
  html += '<section class="section">';
  html += '<div class="section-hd"><div class="section-title">Overview</div></div>';
  html += '<dl class="kv">';
  html += '<dt>Hostname</dt><dd>' + escapeHTML(pc.hostname) + '</dd>';
  html += '<dt>Domain</dt><dd>' + escapeHTML(pc.domain || '—') + '</dd>';
  html += '<dt>OS</dt><dd>' + escapeHTML(pc.os_version || '—') + '</dd>';
  html += '<dt>Last seen</dt><dd>' + (pc.last_seen ? (new Date(pc.last_seen).toLocaleString() + ' (' + fmtAgo(pc.last_seen) + ')') : '—') + '</dd>';
  html += '<dt>Last full scan</dt><dd>' + (pc.last_full_report ? (new Date(pc.last_full_report).toLocaleString() + ' (' + fmtAgo(pc.last_full_report) + ')') : '—') + '</dd>';
  html += '<dt>Updates</dt><dd>' + (pc.update_count < 0 ? 'unknown' : pc.update_count) + '</dd>';
  html += '</dl>';
  html += '</section>';

  // End of Overview panel — open Winget panel.
  html += '</div>'; // /overview
  html += '<div class="modal-panel' + (prevTab==="winget"?' is-active':'') + '" data-modal-panel="winget">';

  // Build a map of live task state per package from pc.tasks. Only consider
  // in-flight tasks (pending/delivered) so that completed tasks from an old
  // winget upgrade don't disable a package row in a newer scan.
  const pkgLiveStatus = {};
  let allUpgradeState = null; // 'pending' | 'delivered' — or null
  let wuAllState = null;
  const wuLiveStatus = {};
  for (const t of (pc.tasks || [])) {
    if (t.status !== 'pending' && t.status !== 'delivered') continue;
    if (t.type === 'upgrade_all') {
      allUpgradeState = t.status;
    } else if (t.type === 'windows_update_all') {
      wuAllState = t.status;
    } else if (t.type === 'windows_update_single' && t.package_id) {
      wuLiveStatus[t.package_id] = { status: t.status };
    } else if (t.package_id) {
      pkgLiveStatus[t.package_id] = { status: t.status, task_id: t.id, type: t.type };
    }
  }

  html += '<section class="section" data-pkg-section>';
  html += '<div class="section-hd"><div class="section-title">Pending updates (' + pkgs.length + ')</div>';
  if (pkgs.length > 0) {
    const allDisabled = !!allUpgradeState;
    const allLabel = allUpgradeState === 'pending' ? 'Upgrading all…' : allUpgradeState === 'delivered' ? 'Running…' : 'Upgrade all';
    html += '<button class="btn btn-sm btn-primary" id="upgrade-all-btn" data-action="upgrade-all" data-host="' + escapeHTML(pc.hostname) + '"' + (allDisabled ? ' disabled' : '') + '>' + escapeHTML(allLabel) + '</button>';
  }
  html += '</div>';
  if (pkgs.length === 0) {
    html += '<div class="card-empty">No pending updates.</div>';
  } else {
    html += '<div class="bulk-bar is-hidden" id="bulk-bar">';
    html += '<div class="bulk-left">';
    html += '<label><input type="checkbox" id="select-all"> Select all</label>';
    html += '<span id="bulk-count-text"><span class="bulk-count">0</span> selected</span>';
    html += '</div>';
    html += '<div style="display:inline-flex;gap:6px">';
    html += '<button class="btn btn-sm btn-ghost" id="deselect-all">Deselect all</button>';
    html += '<button class="btn btn-sm btn-primary" id="bulk-upgrade" data-host="' + escapeHTML(pc.hostname) + '">Upgrade selected</button>';
    html += '</div>';
    html += '</div>';
    html += '<div class="pkg-list">';
    for (const p of pkgs) {
      const pid = p.id || '';
      const pname = p.name || '';
      const effectiveStatus = allUpgradeState || pkgLiveStatus[pid]?.status || '';
      const rowCls = effectiveStatus === 'delivered' || effectiveStatus === 'pending' ? ' is-running' : '';
      const disabled = effectiveStatus === 'pending' || effectiveStatus === 'delivered';
      html += '<label class="pkg' + rowCls + '" data-pkg-row="' + escapeHTML(pid) + '">';
      html += '<input type="checkbox" class="pkg-check" data-id="' + escapeHTML(pid) + '" data-name="' + escapeHTML(pname) + '"' + (disabled ? ' disabled' : '') + '>';
      html += '<div><strong>' + escapeHTML(pname || pid || '?') + '</strong><div class="pkg-id">' + escapeHTML(pid) + '</div></div>';
      html += '<span class="pkg-v">' + escapeHTML(p.version || '?') + '</span>';
      html += '<span class="pkg-arrow">→</span>';
      html += '<span class="pkg-v"><strong>' + escapeHTML(p.available || '?') + '</strong></span>';
      html += '<span class="pkg-status" data-pkg-status="' + escapeHTML(pid) + '">' + pkgStatusChip(effectiveStatus) + '</span>';
      html += '<button class="btn btn-sm btn-cta-outline" data-action="upgrade-one" data-host="' + escapeHTML(pc.hostname) + '" data-id="' + escapeHTML(pid) + '" data-name="' + escapeHTML(pname) + '"' + (disabled ? ' disabled' : '') + '>' + (disabled ? '…' : 'Upgrade') + '</button>';
      html += '</label>';
    }
    html += '</div>';
  }
  html += '</section>';
  html += '</div>'; // /winget

  // ---- Windows updates panel --------------------------------------------
  html += '<div class="modal-panel' + (prevTab==="wu"?' is-active':'') + '" data-modal-panel="wu">';
  html += '<section class="section" data-wu-section>';
  html += '<div class="section-hd"><div class="section-title">Pending Windows updates (' + wu.length + ')</div>';
  if (wu.length > 0) {
    const running = !!wuAllState;
    const label = wuAllState === 'pending' ? 'Queued…' : wuAllState === 'delivered' ? 'Running…' : 'Install all';
    html += '<button class="btn btn-sm btn-primary" id="wu-install-all-btn" data-action="wu-install-all" data-host="' + escapeHTML(pc.hostname) + '"' + (running?' disabled':'') + '>' + escapeHTML(label) + '</button>';
  }
  html += '</div>';
  if (wu.length === 0) {
    html += '<div class="card-empty">No Windows updates pending.</div>';
  } else {
    html += '<div class="wu-list">';
    for (const u of wu) {
      const id = u.update_id || '';
      const sev = (u.severity || '').toLowerCase();
      const effStatus = wuAllState || wuLiveStatus[id]?.status || '';
      const rowCls = effStatus === 'pending' || effStatus === 'delivered' ? ' is-running' : '';
      const disabled = effStatus === 'pending' || effStatus === 'delivered';
      const sizeMB = u.size ? (Math.round((u.size/1024/1024)*10)/10).toFixed(1) + ' MB' : '';
      const kbs = Array.isArray(u.kb) ? u.kb.filter(Boolean) : [];
      const kbHTML = kbs.length ? kbs.map(k => '<span class="wu-kb">KB' + escapeHTML(k) + '</span>').join(' ') : '';

      html += '<div class="wu' + rowCls + '" data-wu-row="' + escapeHTML(id) + '">';
      // col 1: icon-ish severity dot
      html += '<span class="wu-severity ' + escapeHTML(sev) + '">' + (u.severity ? escapeHTML(u.severity) : '&nbsp;') + '</span>';
      // col 2: title + meta
      html += '<div><div class="wu-title">' + escapeHTML(u.title || '(untitled)') + '</div>';
      html += '<div class="wu-meta">' + kbHTML + (kbHTML && sizeMB ? ' · ' : '') + (sizeMB ? escapeHTML(sizeMB) : '') + (u.reboot_required ? ' · <span style="color:var(--c-warning);font-weight:600">reboot required</span>' : '') + '</div></div>';
      // col 3: status chip
      html += '<span class="pkg-status" data-wu-status="' + escapeHTML(id) + '">' + pkgStatusChip(effStatus) + '</span>';
      // col 4: install button
      html += '<button class="btn btn-sm btn-cta-outline" data-action="wu-install-one" data-host="' + escapeHTML(pc.hostname) + '" data-id="' + escapeHTML(id) + '" data-name="' + escapeHTML(u.title || '') + '"' + (disabled?' disabled':'') + '>' + (disabled ? '…' : 'Install') + '</button>';
      html += '</div>';
    }
    html += '</div>';
  }
  html += '</section>';
  html += '</div>'; // /wu

  // Recent tasks / users / admins — belong with Overview. Re-open the panel
  // (hidden unless Overview is selected) and drop them in.
  html += '<div class="modal-panel' + (prevTab==="overview"?' is-active':'') + '" data-modal-panel="overview">';

  if (pc.tasks && pc.tasks.length) {
    html += '<section class="section">';
    html += '<div class="section-hd"><div class="section-title">Recent tasks</div></div>';
    html += '<div class="tbl-wrap"><table class="tbl">';
    html += '<thead><tr><th>When</th><th>Type</th><th>Package</th><th>Status</th><th>Result</th></tr></thead><tbody>';
    for (const t of pc.tasks) {
      const st = t.status === 'completed' ? 'ok' : t.status === 'failed' ? 'danger' : t.status === 'delivered' ? 'info' : 'warn';
      html += '<tr>';
      html += '<td class="sub">' + escapeHTML(t.created_at || '') + '</td>';
      html += '<td>' + escapeHTML(t.type) + '</td>';
      html += '<td class="sub">' + escapeHTML(t.package_name || t.package_id || '—') + '</td>';
      html += '<td><span class="chip ' + st + '"><span class="dot"></span>' + escapeHTML(t.status) + '</span></td>';
      html += '<td class="sub">' + escapeHTML(t.result || '') + '</td>';
      html += '</tr>';
    }
    html += '</tbody></table></div>';
    html += '</section>';
  }

  if (admins.length) {
    html += '<section class="section">';
    html += '<div class="section-hd"><div class="section-title">Local administrators (' + admins.length + ')</div></div>';
    html += '<ul style="list-style:none;padding:0;display:grid;gap:6px">';
    for (const a of admins) html += '<li class="chip info" style="justify-self:start">' + escapeHTML(a.name || a) + '</li>';
    html += '</ul></section>';
  }
  if (users.length) {
    html += '<section class="section">';
    html += '<div class="section-hd"><div class="section-title">Local users (' + users.length + ')</div></div>';
    html += '<div class="tbl-wrap"><table class="tbl">';
    html += '<thead><tr><th>Name</th><th>Full name</th><th>Enabled</th><th>Last logon</th></tr></thead><tbody>';
    for (const u of users) {
      html += '<tr><td><strong>' + escapeHTML(u.name || '') + '</strong></td>';
      html += '<td class="sub">' + escapeHTML(u.full_name || '') + '</td>';
      html += '<td>' + (u.enabled ? '<span class="chip ok"><span class="dot"></span>enabled</span>' : '<span class="chip muted">disabled</span>') + '</td>';
      html += '<td class="sub">' + escapeHTML(u.last_logon || '') + '</td></tr>';
    }
    html += '</tbody></table></div></section>';
  }
  html += '</div>'; // /overview (continuation)
  document.getElementById('device-modal-body').innerHTML = html;
  bindBulkSelect();
  bindModalTabs();
}

function bindModalTabs() {
  document.querySelectorAll('[data-modal-tab]').forEach(btn => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.modalTab;
      document.querySelectorAll('[data-modal-tab]').forEach(b => b.classList.toggle('is-active', b.dataset.modalTab === key));
      document.querySelectorAll('[data-modal-panel]').forEach(p => p.classList.toggle('is-active', p.dataset.modalPanel === key));
    });
  });
}

// One-time binding for the persistent log-clear button.
document.getElementById('log-clear-btn')?.addEventListener('click', () => {
  const el = document.getElementById('live-log');
  if (el) el.innerHTML = '';
});

// ---- Bulk select / deselect / bulk upgrade -------------------------------
function bindBulkSelect() {
  const bar = document.getElementById('bulk-bar');
  if (!bar) return;
  const all = document.getElementById('select-all');
  const deselect = document.getElementById('deselect-all');
  const bulk = document.getElementById('bulk-upgrade');
  const countEl = bar.querySelector('.bulk-count');
  const boxes = () => Array.from(document.querySelectorAll('.pkg-check'));
  const checked = () => boxes().filter(b => b.checked);

  function syncState() {
    const sel = checked();
    countEl.textContent = sel.length;
    bar.classList.toggle('is-hidden', sel.length === 0);
    // sync select-all state
    if (all) {
      const all_cnt = boxes().length;
      all.checked = sel.length > 0 && sel.length === all_cnt;
      all.indeterminate = sel.length > 0 && sel.length < all_cnt;
    }
    // row visual state
    boxes().forEach(b => b.closest('.pkg').classList.toggle('is-checked', b.checked));
  }

  boxes().forEach(b => b.addEventListener('change', syncState));
  if (all) all.addEventListener('change', () => { boxes().forEach(b => b.checked = all.checked); syncState(); });
  if (deselect) deselect.addEventListener('click', () => { boxes().forEach(b => b.checked = false); syncState(); });
  if (bulk) bulk.addEventListener('click', async () => {
    const sel = checked();
    if (!sel.length) return;
    const host = bulk.dataset.host;
    bulk.disabled = true; bulk.textContent = 'Queuing…';
    popLogPane();
    let ok = 0, fail = 0;
    for (const b of sel) {
      setPkgRowStatus(b.dataset.id, 'pending');
      try {
        await createTaskQuiet({ hostname: host, type: 'upgrade_package', package_id: b.dataset.id, package_name: b.dataset.name });
        ok++;
      } catch {
        fail++;
        setPkgRowStatus(b.dataset.id, 'failed');
      }
    }
    bulk.disabled = false; bulk.textContent = 'Upgrade selected';
    toast(ok + ' task(s) queued' + (fail ? (', ' + fail + ' failed') : ''), fail ? 'warn' : 'ok');
    boxes().forEach(b => b.checked = false); syncState();
  });
}

async function createTaskQuiet(payload) {
  const res = await fetch(API + '?action=create_task', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload),
  });
  const json = await res.json();
  if (!res.ok || json.error) throw new Error(json.error || 'HTTP ' + res.status);
  return json;
}

// Only the checkbox itself toggles the row selection. Everything else inside
// the label (including the Upgrade button) must not trigger a toggle.
document.addEventListener('click', (e) => {
  const lbl = e.target.closest('label.pkg');
  if (!lbl) return;
  if (e.target.closest('.pkg-check')) return; // native toggle
  e.preventDefault();
}, true);

// ---- WebSocket live updates ----------------------------------------------
const wsEl = document.getElementById('ws-status');
const wsLabel = wsEl?.querySelector('.ws-label');
function setWsState(state, label) {
  if (!wsEl) return;
  wsEl.classList.remove('is-live', 'is-down');
  wsEl.classList.add(state === 'live' ? 'is-live' : 'is-down');
  if (wsLabel) wsLabel.textContent = label;
}
let wsBackoff = 1000;
let ws;
function connectWS() {
  const proto = location.protocol === 'https:' ? 'wss:' : 'ws:';
  const url = proto + '//' + location.host + '/api/?action=ws';
  try { ws = new WebSocket(url); }
  catch (e) { setWsState('down', 'offline'); scheduleReconnect(); return; }
  ws.onopen = () => { setWsState('live', 'live'); wsBackoff = 1000; };
  ws.onclose = () => { setWsState('down', 'offline'); scheduleReconnect(); };
  ws.onerror = () => { /* close will fire next */ };
  ws.onmessage = (e) => {
    try {
      const ev = JSON.parse(e.data);
      handleWsEvent(ev);
    } catch (err) { /* ignore */ }
  };
}
function scheduleReconnect() {
  wsBackoff = Math.min(wsBackoff * 2, 30000);
  setTimeout(connectWS, wsBackoff);
}
function handleWsEvent(ev) {
  if (ev.type === 'hello') return;
  if (ev.type === 'pc' && ev.data) {
    renderOrUpdateRow(ev.data);
    // if modal is open for this host, soft-refresh its body
    const modalTitle = document.getElementById('device-modal-title');
    if (modal.classList.contains('is-open') && modalTitle && modalTitle.textContent === ev.data.hostname) {
      renderDeviceModal(ev.data);
    }
  } else if (ev.type === 'task' && ev.data) {
    const modalTitle = document.getElementById('device-modal-title');
    const open = modal.classList.contains('is-open') && modalTitle && modalTitle.textContent === ev.data.hostname;
    if (open) {
      if (ev.data.type === 'upgrade_all') {
        setAllUpgradeState(ev.data.status);
      } else if (ev.data.type === 'windows_update_all') {
        setWUAllState(ev.data.status);
      } else if (ev.data.type === 'windows_update_single' && ev.data.package_id) {
        setWURowStatus(ev.data.package_id, ev.data.status, { flash: ev.data.status === 'completed' });
      } else if (ev.data.package_id) {
        setPkgRowStatus(ev.data.package_id, ev.data.status, { flash: ev.data.status === 'completed' });
      }
      // If an upgrade finished (success or fail), the agent will shortly emit
      // a post_task_report → 'pc' event that refreshes the full modal and
      // drops any package that's no longer pending. Nothing more to do here.
    }
  } else if (ev.type === 'pc_online' && ev.data) {
    updateOnlinePill(ev.data.hostname, !!ev.data.online);
  } else if (ev.type === 'log' && ev.data) {
    appendLogLine(ev.data);
  } else if (ev.type === 'pc_removed' && ev.data) {
    const host = ev.data.hostname;
    const tr = document.querySelector('#device-table tbody tr[data-host="' + cssEscape(host) + '"]');
    if (tr) { tr.style.transition = 'opacity .4s'; tr.style.opacity = '0'; setTimeout(() => tr.remove(), 400); setTimeout(updateStats, 500); }
    // Close the modal if we're looking at the removed host.
    const modalTitle = document.getElementById('device-modal-title');
    if (modal.classList.contains('is-open') && modalTitle && modalTitle.textContent === host) closeModal();
    toast(host + ' removed from server', 'ok');
  } else if (ev.type === 'domain' && ev.data) {
    // visual hint only; full reload keeps table simple and consistent.
    toast('Domain list changed — refreshing', 'ok');
    setTimeout(() => location.reload(), 600);
  }
}
connectWS();

// ---- Live row update ------------------------------------------------------
function renderOrUpdateRow(pc) {
  const tbody = document.querySelector('#device-table tbody');
  if (!tbody) return;
  const existing = tbody.querySelector('tr[data-host="' + cssEscape(pc.hostname) + '"]');
  const tr = document.createElement('tr');
  tr.className = 'is-clickable is-flash';
  tr.dataset.host = pc.hostname;
  tr.dataset.domain = pc.domain || '';
  tr.dataset.search = [pc.hostname, pc.domain || '', pc.os_version || ''].join(' ');
  tr.innerHTML = renderRowCells(pc);
  if (existing) existing.replaceWith(tr);
  else {
    // remove empty-state row if present
    const empty = tbody.querySelector('td[colspan]');
    if (empty) empty.parentElement.remove();
    tbody.prepend(tr);
  }
  applyFilter();
  updateStats();
}

function renderRowCells(pc) {
  const last = pc.last_seen ? new Date(pc.last_seen) : null;
  const lastFmt = last ? (last.toISOString().slice(0,16).replace('T', ' ')) : 'Never';
  const wc = (typeof pc.update_count === 'number') ? pc.update_count : -1;
  let uc;
  try {
    const arr = pc.windows_updates ? (typeof pc.windows_updates === 'string' ? JSON.parse(pc.windows_updates) : pc.windows_updates) : null;
    uc = Array.isArray(arr) ? arr.length : -1;
  } catch { uc = -1; }

  function updChip(label, n) {
    if (n < 0)  return '<span class="chip upd-unknown"><span class="src">' + label + '</span>?</span>';
    if (n === 0) return '<span class="chip upd-clean"><span class="src">' + label + '</span>0</span>';
    return '<span class="chip upd-pending"><span class="src">' + label + '</span>' + n + '</span>';
  }
  const updatesCell = '<div class="upd-stack">' + updChip('winget', wc) + updChip('WU', uc) + '</div>';

  let statusChip;
  if (!pc.last_seen)             statusChip = '<span class="chip muted"><span class="dot"></span>never seen</span>';
  else if (wc < 0 && uc < 0)     statusChip = '<span class="chip muted"><span class="dot"></span>unknown</span>';
  else if (wc > 0 || uc > 0)     statusChip = '<span class="chip warn"><span class="dot"></span>updates pending</span>';
  else                            statusChip = '<span class="chip ok"><span class="dot"></span>up to date</span>';

  const host = escapeHTML(pc.hostname);
  const onlineChip = pc.online
    ? '<span class="chip online" data-host-online><span class="dot"></span>online</span>'
    : '<span class="chip offline" data-host-online><span class="dot"></span>offline</span>';
  return '' +
    '<td><div style="display:flex;align-items:center;gap:8px"><span class="hostname">' + host + '</span>' + onlineChip + '</div>' +
      (pc.check_user ? '<div class="sub">' + escapeHTML(pc.check_user) + '</div>' : '') +
    '</td>' +
    '<td>' + (pc.domain ? ('<span class="chip muted">' + escapeHTML(pc.domain) + '</span>') : '<span class="chip muted">—</span>') + '</td>' +
    '<td class="sub os-cell">' + escapeHTML(pc.os_version || '—') + '</td>' +
    '<td class="sub">' + lastFmt + '</td>' +
    '<td>' + updatesCell + '</td>' +
    '<td>' + statusChip + '</td>' +
    '<td><div class="row-actions">' +
      '<button class="btn btn-sm" data-action="view" data-host="' + host + '">Details</button>' +
      '<button class="btn btn-sm btn-primary" data-action="upgrade-all" data-host="' + host + '">Upgrade all</button>' +
    '</div></td>';
}

function updateStats() {
  const rows = Array.from(document.querySelectorAll('#device-table tbody tr[data-host]'));
  let total = rows.length, withU = 0, ok = 0, never = 0;
  rows.forEach(tr => {
    // The status chip is the source of truth; it now considers winget + WU.
    const status = tr.querySelector('td:nth-last-child(2)')?.textContent || '';
    if (status.includes('updates pending')) withU++;
    else if (status.includes('up to date')) ok++;
    if (status.includes('never seen')) never++;
  });
  const vals = document.querySelectorAll('.stat-value');
  if (vals[0]) vals[0].textContent = total;
  if (vals[1]) vals[1].textContent = withU;
  if (vals[2]) vals[2].textContent = ok;
  if (vals[3]) vals[3].textContent = never;
}

function cssEscape(s) { return (window.CSS && CSS.escape) ? CSS.escape(s) : String(s).replace(/"/g, '\\"'); }

// ---- online pill + live log -----------------------------------------------
function updateOnlinePill(host, online) {
  const tr = document.querySelector('#device-table tbody tr[data-host="' + cssEscape(host) + '"]');
  if (tr) {
    tr.dataset.online = online ? '1' : '0';
    const chip = tr.querySelector('[data-host-online]');
    if (chip) {
      chip.className = 'chip ' + (online ? 'online' : 'offline');
      chip.innerHTML = '<span class="dot"></span>' + (online ? 'online' : 'offline');
    }
  }
}

function appendLogLine(data) {
  // Only render log frames for the host whose modal is currently open.
  const log = document.getElementById('live-log');
  if (!log) return;
  if (log.dataset.host !== data.hostname) return;
  const line = document.createElement('span');
  line.className = 'log-line';
  line.innerHTML = '<span class="log-ts">' + escapeHTML(data.ts || '') + '</span>' + escapeHTML(data.line || '');
  log.appendChild(line);
  // Cap at ~1000 lines to avoid memory bloat.
  while (log.childElementCount > 1000) log.removeChild(log.firstChild);
  // Auto-scroll to bottom.
  log.scrollTop = log.scrollHeight;
}

// Map a task status to the chip HTML shown next to each package row.
function pkgStatusChip(status) {
  switch (status) {
    case 'pending':   return '<span class="chip info" title="Queued — waiting for the agent to pick it up"><span class="dot"></span>queued</span>';
    case 'delivered': return '<span class="chip info" title="Running on the host"><span class="dot is-spin"></span>running</span>';
    case 'completed': return '<span class="chip ok" title="Completed"><span class="dot"></span>done</span>';
    case 'failed':    return '<span class="chip danger" title="Failed"><span class="dot"></span>failed</span>';
    default:          return '';
  }
}

// Update a single package row with a new task status (queued/running/done/failed).
function setPkgRowStatus(pid, status, opts) {
  const row = document.querySelector('label.pkg[data-pkg-row="' + cssEscape(pid) + '"]');
  if (!row) return;
  const chip = row.querySelector('.pkg-status');
  if (chip) chip.innerHTML = pkgStatusChip(status);
  row.classList.remove('is-running', 'is-done', 'is-failed');
  if (status === 'pending' || status === 'delivered') {
    row.classList.add('is-running');
  } else if (status === 'completed') {
    row.classList.add('is-done');
  } else if (status === 'failed') {
    row.classList.add('is-failed');
  }
  const cb = row.querySelector('.pkg-check');
  const btn = row.querySelector('button[data-action="upgrade-one"]');
  const locked = status === 'pending' || status === 'delivered';
  if (cb) cb.disabled = locked;
  if (btn) {
    btn.disabled = locked;
    btn.textContent = locked ? '…' : 'Upgrade';
  }
  if (opts && opts.flash) {
    row.animate(
      [{ background: '#DBEAFE' }, { background: getComputedStyle(row).backgroundColor }],
      { duration: 900, easing: 'ease-out' }
    );
  }
}

// Update the global "Upgrade all" button when an upgrade_all task comes in.
function setAllUpgradeState(status) {
  const btn = document.getElementById('upgrade-all-btn');
  if (btn) {
    const running = status === 'pending' || status === 'delivered';
    btn.disabled = running;
    btn.textContent = status === 'pending' ? 'Upgrading all…' : status === 'delivered' ? 'Running…' : 'Upgrade all';
  }
  // Paint every pkg row with the same status until a fresh pc update arrives.
  document.querySelectorAll('label.pkg[data-pkg-row]').forEach(row => {
    setPkgRowStatus(row.dataset.pkgRow, status || 'pending');
  });
}

// -- Windows updates: per-row + install-all state helpers -----------------
function setWURowStatus(id, status, opts) {
  const row = document.querySelector('.wu[data-wu-row="' + cssEscape(id) + '"]');
  if (!row) return;
  const chip = row.querySelector('[data-wu-status]');
  if (chip) chip.innerHTML = pkgStatusChip(status);
  row.classList.toggle('is-running', status === 'pending' || status === 'delivered');
  const btn = row.querySelector('button[data-action="wu-install-one"]');
  if (btn) {
    const locked = status === 'pending' || status === 'delivered';
    btn.disabled = locked;
    btn.textContent = locked ? '…' : 'Install';
  }
  if (opts && opts.flash) {
    row.animate([{ background: '#DBEAFE' }, { background: getComputedStyle(row).backgroundColor }],
      { duration: 900, easing: 'ease-out' });
  }
}

function setWUAllState(status) {
  const btn = document.getElementById('wu-install-all-btn');
  if (btn) {
    const running = status === 'pending' || status === 'delivered';
    btn.disabled = running;
    btn.textContent = status === 'pending' ? 'Queued…' : status === 'delivered' ? 'Running…' : 'Install all';
  }
  document.querySelectorAll('.wu[data-wu-row]').forEach(row => {
    setWURowStatus(row.dataset.wuRow, status || 'pending');
  });
}

// ---- user menu / logout ---------------------------------------------------
const userBtn = document.getElementById('user-btn');
const userPop = document.getElementById('user-pop');
userBtn?.addEventListener('click', (e) => {
  e.stopPropagation();
  userPop.classList.toggle('is-open');
  userBtn.setAttribute('aria-expanded', userPop.classList.contains('is-open'));
});
document.addEventListener('click', (e) => {
  if (!e.target.closest('.user-menu')) userPop?.classList.remove('is-open');
});

document.getElementById('logout-btn')?.addEventListener('click', async () => {
  try {
    await fetch(API + '?action=logout', { method: 'POST', credentials: 'same-origin' });
  } catch {}
  location.replace('/login');
});

// ---- Force-remove button -------------------------------------------------
document.getElementById('force-remove-btn')?.addEventListener('click', async (e) => {
  const host = e.currentTarget.dataset.host;
  if (!host) return;
  if (!confirm('Force-remove ' + host + ' from the server? The agent on that host (if any) will be left installed — use the normal "Uninstall & remove" when possible. Continue?')) return;
  try {
    const res = await fetch(API + '?action=remove_device', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin',
      body: JSON.stringify({ hostname: host, force: true }),
    });
    const j = await res.json();
    if (!res.ok || j.error) throw new Error(j.error || 'HTTP ' + res.status);
    toast(host + ' force-removed', 'ok');
    closeModal();
  } catch (err) { toast(err.message, 'err'); }
});

// Patch viewDevice so the force-remove button also gets the host.
const _origViewDevice = viewDevice;
viewDevice = async function(host) {
  document.getElementById('force-remove-btn').dataset.host = host;
  return _origViewDevice(host);
};

// ---- Profile / TOTP ------------------------------------------------------
const profileModal = document.getElementById('profile-modal');
function openProfile() {
  document.getElementById('profile-sub').textContent = CURRENT_USER.username + ' · ' + CURRENT_USER.role;
  renderTOTPState();
  profileModal.classList.add('is-open');
  document.body.style.overflow = 'hidden';
}
document.getElementById('open-profile')?.addEventListener('click', () => { userPop.classList.remove('is-open'); openProfile(); });
profileModal.addEventListener('click', (e) => {
  if (e.target === profileModal || e.target.closest('[data-close]')) {
    profileModal.classList.remove('is-open'); document.body.style.overflow = '';
  }
});

function renderTOTPState() {
  const box = document.getElementById('totp-state');
  if (CURRENT_USER.totp_enabled) {
    box.innerHTML = '<div class="totp-box">' +
      '<strong>Two-factor is enabled.</strong>' +
      '<div style="margin-top:6px;color:var(--c-muted);font-size:12px">You will be prompted for a 6-digit code at sign-in.</div>' +
      '<div style="margin-top:10px"><button class="btn btn-danger btn-sm" id="totp-disable-btn">Disable 2FA</button></div>' +
      '</div>';
    document.getElementById('totp-disable-btn').addEventListener('click', totpDisable);
  } else {
    box.innerHTML = '<div class="totp-box">' +
      'Two-factor is <strong>not enabled</strong>. Protect this account with an authenticator app (Google Authenticator, 1Password, Authy, …).' +
      '<div style="margin-top:10px"><button class="btn btn-primary btn-sm" id="totp-begin-btn">Enable 2FA</button></div>' +
      '</div>';
    document.getElementById('totp-begin-btn').addEventListener('click', totpBegin);
  }
}

async function totpBegin() {
  try {
    const res = await fetch(API + '?action=totp_begin', { method: 'POST', credentials: 'same-origin' });
    const j = await res.json();
    if (!res.ok || j.error) throw new Error(j.error || 'HTTP ' + res.status);
    const box = document.getElementById('totp-state');
    box.innerHTML = '<div class="totp-box">' +
      '<div>Open your authenticator app and add a new account. Paste this URL, <strong>or</strong> type the secret manually:</div>' +
      '<div style="margin-top:10px"><span class="totp-secret" id="totp-secret">' + escapeHTML(j.secret) + '</span></div>' +
      '<div class="mono" style="font-size:11px;color:var(--c-muted);word-break:break-all;margin-top:6px">' + escapeHTML(j.otpauth_url) + '</div>' +
      '<div class="field" style="margin-top:12px"><label>Enter the current 6-digit code</label><input type="text" id="totp-verify" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" placeholder="000000"></div>' +
      '<div style="margin-top:10px;display:flex;gap:8px"><button class="btn btn-primary btn-sm" id="totp-enable-btn">Verify &amp; enable</button><button class="btn btn-sm" id="totp-cancel-btn">Cancel</button></div>' +
      '</div>';
    document.getElementById('totp-enable-btn').addEventListener('click', () => totpEnable(j.secret));
    document.getElementById('totp-cancel-btn').addEventListener('click', renderTOTPState);
    document.getElementById('totp-verify').focus();
  } catch (err) { toast(err.message, 'err'); }
}

async function totpEnable(secret) {
  const code = document.getElementById('totp-verify').value.trim();
  try {
    const res = await fetch(API + '?action=totp_enable', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin',
      body: JSON.stringify({ secret, code }),
    });
    const j = await res.json();
    if (!res.ok || j.error) throw new Error(j.error || 'HTTP ' + res.status);
    CURRENT_USER.totp_enabled = true;
    toast('Two-factor enabled', 'ok');
    renderTOTPState();
  } catch (err) { toast(err.message, 'err'); }
}

async function totpDisable() {
  const pw = prompt('Enter your current password to disable 2FA:');
  if (!pw) return;
  try {
    const res = await fetch(API + '?action=totp_disable', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin',
      body: JSON.stringify({ current_password: pw }),
    });
    const j = await res.json();
    if (!res.ok || j.error) throw new Error(j.error || 'HTTP ' + res.status);
    CURRENT_USER.totp_enabled = false;
    toast('Two-factor disabled', 'ok');
    renderTOTPState();
  } catch (err) { toast(err.message, 'err'); }
}

document.getElementById('pw-save-btn')?.addEventListener('click', async () => {
  const cur = document.getElementById('pw-current').value;
  const nw = document.getElementById('pw-new').value;
  if (!cur || !nw) { toast('Fill both fields', 'warn'); return; }
  try {
    const res = await fetch(API + '?action=change_password', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin',
      body: JSON.stringify({ current_password: cur, new_password: nw }),
    });
    const j = await res.json();
    if (!res.ok || j.error) throw new Error(j.error || 'HTTP ' + res.status);
    document.getElementById('pw-current').value = '';
    document.getElementById('pw-new').value = '';
    toast('Password updated', 'ok');
  } catch (err) { toast(err.message, 'err'); }
});

// ---- User management (admin) --------------------------------------------
const usersTableBody = document.querySelector('#users-table tbody');
const userModal = document.getElementById('user-modal');
let _editingUserId = 0;

async function loadUsers() {
  if (CURRENT_USER.role !== 'admin') return;
  try {
    const res = await fetch(API + '?action=users', { credentials: 'same-origin' });
    const users = await res.json();
    if (!res.ok) throw new Error(users.error || 'HTTP ' + res.status);
    renderUsersTable(users);
  } catch (err) { usersTableBody.innerHTML = '<tr><td colspan="6"><div class="banner is-err">' + escapeHTML(err.message) + '</div></td></tr>'; }
}

function renderUsersTable(users) {
  if (!users.length) { usersTableBody.innerHTML = '<tr><td colspan="6"><div class="empty"><div class="empty-title">No users</div></div></td></tr>'; return; }
  usersTableBody.innerHTML = users.map(u => {
    const roleClass = 'chip role-' + u.role;
    const twofa = u.totp_enabled ? '<span class="chip ok"><span class="dot"></span>enabled</span>' : '<span class="chip muted">off</span>';
    return '<tr data-user-id="' + u.id + '">' +
      '<td><strong>' + escapeHTML(u.username) + '</strong></td>' +
      '<td><span class="' + roleClass + '">' + escapeHTML(u.role) + '</span></td>' +
      '<td>' + twofa + '</td>' +
      '<td class="sub">' + (u.last_login_at ? new Date(u.last_login_at).toLocaleString() : 'Never') + '</td>' +
      '<td class="sub">' + new Date(u.created_at).toLocaleDateString() + '</td>' +
      '<td style="text-align:right"><div class="row-actions">' +
        '<button class="btn btn-sm" data-user-action="edit" data-id="' + u.id + '" data-username="' + escapeHTML(u.username) + '" data-role="' + u.role + '">Edit</button>' +
        '<button class="btn btn-sm btn-danger" data-user-action="delete" data-id="' + u.id + '" data-username="' + escapeHTML(u.username) + '">Delete</button>' +
      '</div></td></tr>';
  }).join('');
}

document.querySelector('[data-tab="users"]')?.addEventListener('click', loadUsers);
document.getElementById('new-user-btn')?.addEventListener('click', () => openUserModal());
usersTableBody?.addEventListener('click', (e) => {
  const btn = e.target.closest('[data-user-action]');
  if (!btn) return;
  const a = btn.dataset.userAction;
  if (a === 'edit') openUserModal({ id: +btn.dataset.id, username: btn.dataset.username, role: btn.dataset.role });
  if (a === 'delete') deleteUser(+btn.dataset.id, btn.dataset.username);
});

function openUserModal(existing) {
  _editingUserId = existing?.id || 0;
  document.getElementById('user-modal-title').textContent = existing ? ('Edit ' + existing.username) : 'Add user';
  document.getElementById('user-edit-id').value = existing?.id || '';
  document.getElementById('user-username-field').style.display = existing ? 'none' : '';
  document.getElementById('user-username').value = existing?.username || '';
  document.getElementById('user-role').value = existing?.role || 'viewer';
  document.getElementById('user-password').value = '';
  document.getElementById('user-password-label').textContent = existing ? 'New password (leave blank to keep)' : 'Password';
  document.getElementById('user-password-hint').textContent = existing ? 'Leave empty to keep existing password.' : 'Minimum 8 characters.';
  userModal.classList.add('is-open');
  document.body.style.overflow = 'hidden';
}
userModal.addEventListener('click', (e) => {
  if (e.target === userModal || e.target.closest('[data-close]')) {
    userModal.classList.remove('is-open'); document.body.style.overflow = '';
  }
});

document.getElementById('user-save-btn')?.addEventListener('click', async () => {
  const id = _editingUserId;
  const role = document.getElementById('user-role').value;
  const password = document.getElementById('user-password').value;
  try {
    if (id) {
      const body = { id, role };
      if (password) body.password = password;
      const res = await fetch(API + '?action=update_user', {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin',
        body: JSON.stringify(body),
      });
      const j = await res.json();
      if (!res.ok || j.error) throw new Error(j.error || 'HTTP ' + res.status);
      toast('User updated', 'ok');
    } else {
      const username = document.getElementById('user-username').value.trim();
      if (!username || password.length < 8) { toast('Username + 8-char password required', 'warn'); return; }
      const res = await fetch(API + '?action=create_user', {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin',
        body: JSON.stringify({ username, password, role }),
      });
      const j = await res.json();
      if (!res.ok || j.error) throw new Error(j.error || 'HTTP ' + res.status);
      toast('User created', 'ok');
    }
    userModal.classList.remove('is-open'); document.body.style.overflow = '';
    loadUsers();
  } catch (err) { toast(err.message, 'err'); }
});

async function deleteUser(id, username) {
  if (!confirm('Delete user ' + username + '? This also invalidates their active sessions.')) return;
  try {
    const res = await fetch(API + '?action=delete_user', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin',
      body: JSON.stringify({ id }),
    });
    const j = await res.json();
    if (!res.ok || j.error) throw new Error(j.error || 'HTTP ' + res.status);
    toast('User deleted', 'ok');
    loadUsers();
  } catch (err) { toast(err.message, 'err'); }
}


function safeParse(v) {
  if (v == null) return null;
  if (typeof v === 'object') return v;
  try { return JSON.parse(v); } catch { return null; }
}

function fmtAgo(iso) {
  if (!iso) return '';
  const d = (Date.now() - new Date(iso).getTime()) / 1000;
  if (d < 60) return Math.floor(d) + 's ago';
  if (d < 3600) return Math.floor(d/60) + 'm ago';
  if (d < 86400) return Math.floor(d/3600) + 'h ago';
  return Math.floor(d/86400) + 'd ago';
}

// ---- Action dispatch ------------------------------------------------------
document.addEventListener('click', async (e) => {
  const btn = e.target.closest('[data-action]');
  if (!btn) {
    // row click → view
    const row = e.target.closest('tr[data-host]');
    if (row && !e.target.closest('button')) viewDevice(row.dataset.host);
    return;
  }
  e.stopPropagation();
  const a = btn.dataset.action;
  if (a === 'view') return viewDevice(btn.dataset.host);
  if (a === 'upgrade-all') {
    setAllUpgradeState('pending');
    popLogPane();
    return createTask({ hostname: btn.dataset.host, type: 'upgrade_all' }, 'Upgrade queued');
  }
  if (a === 'upgrade-one') {
    setPkgRowStatus(btn.dataset.id, 'pending');
    popLogPane();
    return createTask({ hostname: btn.dataset.host, type: 'upgrade_package', package_id: btn.dataset.id, package_name: btn.dataset.name }, 'Package upgrade queued');
  }
  if (a === 'wu-install-all') {
    setWUAllState('pending');
    popLogPane();
    return createTask({ hostname: btn.dataset.host, type: 'windows_update_all' }, 'Windows Update install queued');
  }
  if (a === 'wu-install-one') {
    setWURowStatus(btn.dataset.id, 'pending');
    popLogPane();
    return createTask({ hostname: btn.dataset.host, type: 'windows_update_single', package_id: btn.dataset.id, package_name: btn.dataset.name }, 'Windows Update queued');
  }
  if (a === 'remove-domain') return removeDomain(btn.dataset.id);
});

async function createTask(payload, okMsg) {
  try {
    const res = await fetch(API + '?action=create_task', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });
    const json = await res.json();
    if (!res.ok || json.error) throw new Error(json.error || 'HTTP ' + res.status);
    toast(okMsg, 'ok');
  } catch (e) { toast(e.message, 'err'); }
}

async function removeDomain(id) {
  if (!confirm('Remove this allowed domain? Enrollment from this domain will stop.')) return;
  try {
    const res = await fetch(API + '?action=remove_domain', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: parseInt(id,10) }),
    });
    const json = await res.json();
    if (!res.ok || json.error) throw new Error(json.error || 'HTTP ' + res.status);
    document.querySelector('[data-domain-id="' + id + '"]')?.remove();
    toast('Domain removed', 'ok');
  } catch (e) { toast(e.message, 'err'); }
}

// ---- Add domain -----------------------------------------------------------
