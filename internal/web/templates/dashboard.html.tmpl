<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Corrivex</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  /* Trust & Authority palette */
  --c-primary:   #0F172A;
  --c-secondary: #334155;
  --c-cta:       #0369A1;
  --c-cta-hover: #075985;
  --c-bg:        #F8FAFC;
  --c-surface:   #FFFFFF;
  --c-text:      #020617;
  --c-text-2:    #334155;
  --c-muted:     #64748B;
  --c-border:    #E2E8F0;
  --c-border-2:  #CBD5E1;
  --c-success:   #047857;
  --c-success-bg:#ECFDF5;
  --c-warning:   #B45309;
  --c-warning-bg:#FFFBEB;
  --c-danger:    #B91C1C;
  --c-danger-bg: #FEF2F2;
  --c-info:      #0369A1;
  --c-info-bg:   #EFF6FF;

  --r-sm: 6px;
  --r-md: 8px;
  --r-lg: 12px;
  --r-xl: 16px;

  --shadow-sm: 0 1px 2px 0 rgba(15,23,42,.04);
  --shadow-md: 0 4px 12px -2px rgba(15,23,42,.08), 0 2px 4px -2px rgba(15,23,42,.04);
  --shadow-lg: 0 20px 40px -12px rgba(15,23,42,.15), 0 8px 16px -8px rgba(15,23,42,.08);

  --ease: cubic-bezier(.4,0,.2,1);
  --d-fast: 150ms;
  --d-med:  220ms;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
@media (prefers-reduced-motion: reduce) { html { scroll-behavior: auto; } *,*::before,*::after { transition: none !important; animation: none !important; } }
body {
  background: var(--c-bg);
  color: var(--c-text);
  font-family: 'Plus Jakarta Sans', system-ui, -apple-system, sans-serif;
  font-size: 14px;
  line-height: 1.55;
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}

/* Typography scale */
h1, .h1 { font-size: 24px; font-weight: 700; letter-spacing: -0.015em; color: var(--c-primary); }
h2, .h2 { font-size: 18px; font-weight: 600; letter-spacing: -0.01em; color: var(--c-primary); }
h3, .h3 { font-size: 15px; font-weight: 600; color: var(--c-primary); }
.eyebrow { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--c-muted); }
.mono { font-family: ui-monospace, 'SFMono-Regular', Menlo, Consolas, monospace; }
a { color: var(--c-cta); text-decoration: none; }
a:hover { color: var(--c-cta-hover); text-decoration: underline; }

/* Focus ring */
:focus-visible {
  outline: 2px solid var(--c-cta);
  outline-offset: 2px;
  border-radius: var(--r-sm);
}

/* Top bar */
.topbar {
  position: sticky; top: 0; z-index: 50;
  background: var(--c-surface);
  border-bottom: 1px solid var(--c-border);
  backdrop-filter: saturate(1.6);
}
.topbar-inner {
  max-width: 1440px; margin: 0 auto;
  padding: 14px 24px;
  display: flex; align-items: center; justify-content: space-between; gap: 16px;
}
.brand { display: flex; align-items: center; gap: 10px; }
.brand-mark {
  width: 32px; height: 32px; border-radius: 8px;
  background: linear-gradient(135deg, var(--c-primary), var(--c-secondary));
  display: flex; align-items: center; justify-content: center;
  color: #fff; box-shadow: var(--shadow-sm);
}
.brand-name { font-weight: 700; font-size: 16px; letter-spacing: -0.015em; color: var(--c-primary); }
.brand-tag {
  font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em;
  color: var(--c-muted); padding: 2px 8px; border: 1px solid var(--c-border);
  border-radius: 999px; background: var(--c-bg);
}
.topbar-right { display: flex; align-items: center; gap: 10px; font-size: 12px; color: var(--c-text-2); }
.badge-secure {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 4px 10px; font-size: 11px; font-weight: 600;
  color: var(--c-success); background: var(--c-success-bg);
  border: 1px solid #A7F3D0; border-radius: 999px;
  transition: transform var(--d-fast) var(--ease);
}
.badge-secure:hover { transform: translateY(-1px); }
.badge-secure svg { width: 12px; height: 12px; }

/* Container */
.wrap { max-width: 1440px; margin: 0 auto; padding: 28px 24px 80px; }

/* Stats strip */
.stats {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;
  margin-bottom: 28px;
}
.stat {
  background: var(--c-surface);
  border: 1px solid var(--c-border);
  border-radius: var(--r-lg);
  padding: 18px 20px;
  box-shadow: var(--shadow-sm);
  position: relative; overflow: hidden;
  transition: box-shadow var(--d-med) var(--ease), transform var(--d-med) var(--ease);
}
.stat:hover { box-shadow: var(--shadow-md); transform: translateY(-1px); }
.stat::before {
  content: ''; position: absolute; inset: 0 0 auto 0; height: 3px;
  background: var(--c-border-2);
}
.stat.is-total::before   { background: var(--c-primary); }
.stat.is-updates::before { background: var(--c-warning); }
.stat.is-ok::before      { background: var(--c-success); }
.stat.is-new::before     { background: var(--c-info); }
.stat-label {
  font-size: 11px; font-weight: 600; text-transform: uppercase;
  letter-spacing: 0.08em; color: var(--c-muted); margin-bottom: 6px;
  display: flex; align-items: center; gap: 8px;
}
.stat-label svg { width: 14px; height: 14px; }
.stat-value {
  font-size: 32px; font-weight: 700; letter-spacing: -0.02em;
  color: var(--c-primary); line-height: 1; margin-bottom: 8px;
  opacity: 0; transform: translateY(4px);
  animation: statReveal 600ms var(--ease) forwards;
}
@keyframes statReveal { to { opacity: 1; transform: none; } }
.stat-hint { font-size: 12px; color: var(--c-muted); }
.stat.is-updates .pulse {
  display: inline-block; width: 8px; height: 8px; border-radius: 999px;
  background: var(--c-warning); margin-left: 6px;
  animation: pulse 2s var(--ease) infinite;
}
@keyframes pulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: .55; transform: scale(1.25); } }

/* Tabs */
.tabs {
  display: flex; gap: 4px; border-bottom: 1px solid var(--c-border);
  margin-bottom: 20px; padding: 0 2px;
}
.tab {
  appearance: none; background: none; border: none;
  padding: 10px 14px; font: inherit; font-weight: 500; color: var(--c-text-2);
  cursor: pointer; border-bottom: 2px solid transparent;
  transition: color var(--d-fast) var(--ease), border-color var(--d-fast) var(--ease);
  display: inline-flex; align-items: center; gap: 8px;
}
.tab:hover { color: var(--c-primary); }
.tab svg { width: 16px; height: 16px; }
.tab.is-active { color: var(--c-primary); border-bottom-color: var(--c-cta); }
.tab-panel { display: none; }
.tab-panel.is-active { display: block; }

/* Toolbar */
.toolbar {
  display: flex; align-items: center; justify-content: space-between;
  gap: 16px; margin-bottom: 16px; flex-wrap: wrap;
}
.toolbar-left, .toolbar-right { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
.input {
  font: inherit; font-size: 13px;
  padding: 8px 12px; border: 1px solid var(--c-border-2);
  border-radius: var(--r-md); background: var(--c-surface); color: var(--c-text);
  min-width: 240px;
  transition: border-color var(--d-fast) var(--ease), box-shadow var(--d-fast) var(--ease);
}
.input:hover { border-color: var(--c-muted); }
.input:focus { border-color: var(--c-cta); box-shadow: 0 0 0 3px rgba(3,105,161,.15); outline: none; }
.input::placeholder { color: var(--c-muted); }

/* Buttons */
.btn {
  appearance: none; cursor: pointer;
  font: inherit; font-size: 13px; font-weight: 500;
  padding: 8px 14px; border-radius: var(--r-md);
  border: 1px solid var(--c-border-2); background: var(--c-surface); color: var(--c-text);
  display: inline-flex; align-items: center; gap: 8px;
  transition: background var(--d-fast) var(--ease), border-color var(--d-fast) var(--ease),
    color var(--d-fast) var(--ease), box-shadow var(--d-fast) var(--ease);
}
.btn:hover { background: #F1F5F9; border-color: var(--c-muted); }
.btn:disabled { opacity: .55; cursor: not-allowed; }
.btn svg { width: 14px; height: 14px; }
.btn-primary { background: var(--c-cta); border-color: var(--c-cta); color: #fff; }
.btn-primary:hover { background: var(--c-cta-hover); border-color: var(--c-cta-hover); }
.btn-dark { background: var(--c-primary); border-color: var(--c-primary); color: #fff; }
.btn-dark:hover { background: #1E293B; border-color: #1E293B; }
.btn-danger { background: var(--c-surface); border-color: #FECACA; color: var(--c-danger); }
.btn-danger:hover { background: var(--c-danger-bg); border-color: var(--c-danger); }
.btn-ghost { background: transparent; border-color: transparent; color: var(--c-text-2); }
.btn-ghost:hover { background: #F1F5F9; color: var(--c-primary); }
.btn-sm { padding: 5px 10px; font-size: 12px; border-radius: var(--r-sm); }
.btn-block { width: 100%; justify-content: center; }

/* Card */
.card {
  background: var(--c-surface);
  border: 1px solid var(--c-border);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-sm);
}
.card-hd {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 20px; border-bottom: 1px solid var(--c-border);
}
.card-bd { padding: 20px; }
.card-empty {
  padding: 40px 20px; text-align: center; color: var(--c-muted); font-size: 13px;
}

/* Table */
.tbl-wrap { overflow-x: auto; }
.tbl { width: 100%; border-collapse: collapse; font-size: 13px; }
.tbl th, .tbl td {
  text-align: left; padding: 12px 16px;
  border-bottom: 1px solid var(--c-border); vertical-align: middle;
}
.tbl thead th {
  font-size: 11px; font-weight: 600; text-transform: uppercase;
  letter-spacing: 0.06em; color: var(--c-muted);
  background: #F8FAFC; position: sticky; top: 0;
}
.tbl tbody tr { transition: background var(--d-fast) var(--ease); }
.tbl tbody tr:hover { background: #F8FAFC; }
.tbl tbody tr.is-clickable { cursor: pointer; }
.tbl td .hostname { font-weight: 600; color: var(--c-primary); }
.tbl td .sub { font-size: 11px; color: var(--c-muted); margin-top: 2px; }

.chip {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 3px 10px; font-size: 11px; font-weight: 600;
  border-radius: 999px; border: 1px solid var(--c-border-2);
  background: var(--c-bg); color: var(--c-text-2);
  line-height: 1.4;
}
.chip.ok { color: var(--c-success); background: var(--c-success-bg); border-color: #A7F3D0; }
.chip.warn { color: var(--c-warning); background: var(--c-warning-bg); border-color: #FDE68A; }
.chip.danger { color: var(--c-danger); background: var(--c-danger-bg); border-color: #FECACA; }
.chip.info { color: var(--c-info); background: var(--c-info-bg); border-color: #BFDBFE; }
.chip.muted { color: var(--c-muted); background: var(--c-bg); }
.chip .dot { width: 6px; height: 6px; border-radius: 999px; background: currentColor; }

.row-actions { display: flex; gap: 6px; justify-content: flex-end; }

/* OS column: allow wrapping so long captions like
   "Microsoft Windows 11 Pro for Workstations 10.0.26200" don't blow up the
   table width. */
.tbl td.os-cell {
  max-width: 220px;
  white-space: normal;
  word-wrap: break-word;
  word-break: break-word;
  line-height: 1.35;
}

/* Updates column: two stacked source chips so winget and WU read at a glance. */
.upd-stack { display: flex; flex-direction: column; gap: 4px; align-items: flex-start; }
.upd-stack .chip { font-size: 10.5px; padding: 1px 8px; }
.upd-stack .chip .src { color: var(--c-muted); font-weight: 500; margin-right: 6px; }
.chip.upd-pending { color: var(--c-warning); background: var(--c-warning-bg); border-color: #FDE68A; }
.chip.upd-clean   { color: var(--c-success); background: var(--c-success-bg); border-color: #A7F3D0; }
.chip.upd-unknown { color: var(--c-muted);   background: var(--c-bg);         border-color: var(--c-border); }

/* Modal */
.modal-backdrop {
  position: fixed; inset: 0; z-index: 90;
  background: rgba(15,23,42,.55);
  display: none;
  align-items: center; justify-content: center;
  padding: 24px;
  animation: bdFade var(--d-med) var(--ease);
}
.modal-backdrop.is-open { display: flex; }
@keyframes bdFade { from { opacity: 0; } to { opacity: 1; } }
.modal {
  background: var(--c-surface);
  border-radius: var(--r-xl);
  box-shadow: var(--shadow-lg);
  max-width: 900px; width: 100%; max-height: 86vh;
  display: flex; flex-direction: column;
  animation: mdSlide var(--d-med) var(--ease);
}
@keyframes mdSlide { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: none; } }
.modal-hd {
  padding: 18px 24px; border-bottom: 1px solid var(--c-border);
  display: flex; align-items: center; justify-content: space-between; gap: 12px;
}
.modal-title { font-size: 16px; font-weight: 700; color: var(--c-primary); }
.modal-sub { font-size: 12px; color: var(--c-muted); margin-top: 2px; font-family: ui-monospace, monospace; }
.modal-bd { padding: 20px 24px; overflow-y: auto; }
.modal-ft {
  padding: 14px 24px; border-top: 1px solid var(--c-border);
  display: flex; justify-content: flex-end; gap: 8px;
}
.icon-btn {
  appearance: none; border: none; background: transparent;
  width: 32px; height: 32px; border-radius: var(--r-sm); cursor: pointer;
  color: var(--c-muted);
  display: inline-flex; align-items: center; justify-content: center;
  transition: background var(--d-fast) var(--ease), color var(--d-fast) var(--ease);
}
.icon-btn:hover { background: #F1F5F9; color: var(--c-primary); }
.icon-btn svg { width: 18px; height: 18px; }

/* Sections within modal */
.section + .section { margin-top: 20px; }
.section-hd { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
.section-title { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--c-muted); }

/* Bootstrap command block */
.cmd-block {
  background: var(--c-primary);
  color: #E2E8F0;
  border-radius: var(--r-lg);
  padding: 18px 20px;
  font-family: ui-monospace, 'SFMono-Regular', Menlo, Consolas, monospace;
  font-size: 12px; line-height: 1.6;
  overflow-x: auto; white-space: pre;
  position: relative;
  border: 1px solid #1E293B;
}
.cmd-copy {
  position: absolute; top: 12px; right: 12px;
}

/* Form */
.field { display: flex; flex-direction: column; gap: 6px; }
.field + .field { margin-top: 14px; }
.field label { font-size: 12px; font-weight: 600; color: var(--c-text-2); }
.field .hint { font-size: 11px; color: var(--c-muted); }
.field input, .field select, .field textarea {
  font: inherit; font-size: 13px;
  padding: 8px 12px; border: 1px solid var(--c-border-2);
  border-radius: var(--r-md); background: var(--c-surface); color: var(--c-text);
  transition: border-color var(--d-fast) var(--ease), box-shadow var(--d-fast) var(--ease);
}
.field input:focus, .field select:focus, .field textarea:focus {
  border-color: var(--c-cta); box-shadow: 0 0 0 3px rgba(3,105,161,.15); outline: none;
}

/* Toast */
.toast-stack {
  position: fixed; z-index: 100;
  bottom: 24px; right: 24px; display: flex; flex-direction: column; gap: 10px;
  pointer-events: none;
}
.toast {
  pointer-events: auto;
  background: var(--c-surface);
  border: 1px solid var(--c-border);
  border-left: 3px solid var(--c-cta);
  border-radius: var(--r-md);
  box-shadow: var(--shadow-lg);
  padding: 12px 16px; min-width: 260px; max-width: 380px;
  font-size: 13px; color: var(--c-text);
  display: flex; align-items: flex-start; gap: 10px;
  animation: toastIn var(--d-med) var(--ease);
}
.toast.is-ok    { border-left-color: var(--c-success); }
.toast.is-err   { border-left-color: var(--c-danger); }
.toast.is-warn  { border-left-color: var(--c-warning); }
.toast svg { width: 16px; height: 16px; margin-top: 1px; flex-shrink: 0; }
.toast.is-ok svg   { color: var(--c-success); }
.toast.is-err svg  { color: var(--c-danger); }
.toast.is-warn svg { color: var(--c-warning); }
@keyframes toastIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: none; } }

/* Package list */
.pkg-list { display: flex; flex-direction: column; gap: 8px; }
.pkg {
  display: grid; grid-template-columns: auto 1fr auto auto auto auto auto;
  gap: 12px; align-items: center;
  padding: 10px 14px; border: 1px solid var(--c-border); border-radius: var(--r-md);
  background: var(--c-surface); font-size: 13px;
  transition: background var(--d-fast) var(--ease), border-color var(--d-fast) var(--ease);
}
.pkg:hover { background: #F8FAFC; border-color: var(--c-border-2); }
.pkg.is-checked { background: #EFF6FF; border-color: #BFDBFE; }
.pkg.is-running { background: #EFF6FF; border-color: #BFDBFE; }
.pkg.is-done    { background: var(--c-success-bg); border-color: #A7F3D0; }
.pkg.is-failed  { background: var(--c-danger-bg); border-color: #FECACA; }
.pkg-status { min-width: 78px; display: inline-flex; justify-content: flex-end; }
.pkg-status .chip { display: inline-flex; }

/* animated dot for in-progress status */
.chip.info .dot, .chip .dot.is-spin {
  animation: pulse 1.4s var(--ease) infinite;
}
.pkg-id { font-family: ui-monospace, monospace; font-size: 11px; color: var(--c-muted); margin-top: 2px; word-break: break-all; }
.pkg-v { font-family: ui-monospace, monospace; font-size: 12px; color: var(--c-text-2); white-space: nowrap; }
.pkg-arrow { color: var(--c-muted); font-family: ui-monospace, monospace; }
.pkg-check { width: 16px; height: 16px; cursor: pointer; accent-color: var(--c-cta); margin: 0; }

/* Bulk-select action bar inside the modal */
.bulk-bar {
  display: flex; align-items: center; justify-content: space-between;
  gap: 12px; padding: 10px 14px;
  border: 1px solid #BFDBFE; background: #EFF6FF;
  border-radius: var(--r-md); margin-bottom: 10px;
  font-size: 13px; color: var(--c-info);
}
.bulk-bar.is-hidden { display: none; }
.bulk-left { display: inline-flex; align-items: center; gap: 10px; color: var(--c-text-2); font-weight: 500; }
.bulk-left label { display: inline-flex; align-items: center; gap: 6px; cursor: pointer; }
.bulk-left input[type=checkbox] { accent-color: var(--c-cta); width: 16px; height: 16px; cursor: pointer; }
.bulk-count { font-weight: 600; color: var(--c-info); }

/* CTA-outline button: strong border + CTA color, clearly visible on any surface */
.btn-cta-outline {
  background: var(--c-surface);
  border: 1.5px solid var(--c-cta);
  color: var(--c-cta);
  font-weight: 600;
}
.btn-cta-outline:hover {
  background: var(--c-cta);
  border-color: var(--c-cta);
  color: #fff;
}

/* WebSocket live-status indicator */
.ws-status {
  display: inline-flex; align-items: center; gap: 6px;
  font-size: 11px; color: var(--c-muted); user-select: none;
  padding: 3px 10px; border: 1px solid var(--c-border);
  border-radius: 999px; background: var(--c-bg);
}
.ws-status .ws-dot {
  width: 7px; height: 7px; border-radius: 999px; background: #CBD5E1;
  transition: background var(--d-med) var(--ease);
}
.ws-status.is-live { color: var(--c-success); border-color: #A7F3D0; background: var(--c-success-bg); }
.ws-status.is-live .ws-dot { background: var(--c-success); animation: pulse 2s var(--ease) infinite; }
.ws-status.is-down { color: var(--c-warning); border-color: #FDE68A; background: var(--c-warning-bg); }
.ws-status.is-down .ws-dot { background: var(--c-warning); }
.tbl tbody tr.is-flash { animation: rowFlash 1200ms var(--ease); }
@keyframes rowFlash { 0% { background: #DBEAFE; } 100% { background: transparent; } }

/* --- user menu in topbar ------------------------------------------------ */
.user-menu { position: relative; }
.user-btn {
  appearance: none; background: var(--c-bg); border: 1px solid var(--c-border);
  border-radius: 999px; cursor: pointer;
  display: inline-flex; align-items: center; gap: 10px;
  padding: 4px 10px 4px 4px; font: inherit;
  transition: border-color var(--d-fast) var(--ease), background var(--d-fast) var(--ease);
}
.user-btn:hover { border-color: var(--c-muted); background: var(--c-surface); }
.user-avatar {
  width: 28px; height: 28px; border-radius: 999px;
  background: linear-gradient(135deg, var(--c-cta), var(--c-primary));
  color: #fff; font-weight: 700; font-size: 12px; text-transform: uppercase;
  display: inline-flex; align-items: center; justify-content: center;
}
.user-meta { display: inline-flex; flex-direction: column; line-height: 1.15; text-align: left; }
.user-name { font-size: 12px; font-weight: 600; color: var(--c-primary); }
.user-role { font-size: 10px; color: var(--c-muted); text-transform: uppercase; letter-spacing: 0.08em; }
.user-pop {
  position: absolute; right: 0; top: calc(100% + 6px); min-width: 180px;
  background: var(--c-surface); border: 1px solid var(--c-border);
  border-radius: var(--r-md); box-shadow: var(--shadow-lg);
  padding: 6px; display: none; z-index: 60;
}
.user-pop.is-open { display: block; animation: bdFade var(--d-fast) var(--ease); }
.user-item {
  appearance: none; background: none; border: 0; cursor: pointer;
  width: 100%; padding: 8px 10px; border-radius: var(--r-sm);
  display: inline-flex; align-items: center; gap: 10px;
  color: var(--c-text); font: inherit; font-size: 13px;
  transition: background var(--d-fast) var(--ease);
}
.user-item:hover { background: #F1F5F9; }
.user-item svg { width: 16px; height: 16px; color: var(--c-muted); }

/* --- small helpers for role badges ------------------------------------- */
.chip.role-admin    { color: #6D28D9; background: #F5F3FF; border-color: #DDD6FE; }
.chip.role-operator { color: var(--c-cta); background: var(--c-info-bg); border-color: #BFDBFE; }
.chip.role-viewer   { color: var(--c-muted); background: var(--c-bg); border-color: var(--c-border); }

/* Admin-only elements stay hidden for everyone *except* admins. For admins
   the element falls back to its own CSS (modal stays hidden until .is-open,
   tab-panel stays hidden until .is-active, tab button shows inline-flex). */
body:not(.is-admin) [data-admin-only] { display: none !important; }

/* TOTP setup block */
.totp-box {
  background: var(--c-bg); border: 1px solid var(--c-border);
  border-radius: var(--r-md); padding: 14px 16px; font-size: 13px;
}
.totp-secret {
  font-family: ui-monospace, monospace; font-size: 16px; font-weight: 600;
  letter-spacing: .04em; color: var(--c-primary);
  padding: 8px 12px; background: var(--c-surface); border: 1px dashed var(--c-border-2);
  border-radius: var(--r-sm); display: inline-block; margin: 6px 0;
}
.stale-dot { display:inline-block;width:6px;height:6px;border-radius:999px;background:var(--c-danger);margin-right:6px;vertical-align:middle }

/* Online/offline pill next to the hostname */
.chip.online  { color: var(--c-success); background: var(--c-success-bg); border-color: #A7F3D0; }
.chip.offline { color: var(--c-muted);   background: var(--c-bg);         border-color: var(--c-border); }
.chip.online .dot  { background: var(--c-success); animation: pulse 2s var(--ease) infinite; }
.chip.offline .dot { background: var(--c-muted); }

/* Live log console in the device modal */
.log-console {
  background: var(--c-primary);
  color: #E2E8F0;
  font-family: ui-monospace, 'SFMono-Regular', Menlo, Consolas, monospace;
  font-size: 11.5px; line-height: 1.55;
  padding: 10px 14px;
  border-radius: var(--r-md);
  max-height: 280px; overflow-y: auto;
  border: 1px solid #1E293B;
  white-space: pre-wrap; word-break: break-all;
}
.log-console:empty::before { content: 'Waiting for live output…'; color: #64748B; font-style: italic; }
.log-line { display: block; padding: 1px 0; }
.log-line .log-ts { color: #94A3B8; margin-right: 8px; }
.log-empty { color: #64748B; font-style: italic; }

/* Persistent live-log pane pinned inside the modal, below the scrollable body
   and above the footer. Survives renderDeviceModal() re-renders triggered by
   'pc' WebSocket events, so user sees an uninterrupted stream. */
.modal .modal-bd { flex: 1 1 auto; }
.modal-log {
  flex: 0 0 auto;
  display: flex; flex-direction: column; gap: 8px;
  padding: 12px 24px 14px;
  background: var(--c-bg);
  border-top: 1px solid var(--c-border);
  max-height: 260px;
  transition: box-shadow 350ms var(--ease);
}
.modal-log-hd {
  display: flex; align-items: center; justify-content: space-between;
  gap: 10px;
}
.modal-log .section-title {
  font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--c-muted);
  display: inline-flex; align-items: center; gap: 8px;
}
.modal-log .section-title .live-dot {
  display: inline-block; width: 8px; height: 8px; border-radius: 999px;
  background: var(--c-border-2);
}
.modal-log.is-live .section-title .live-dot {
  background: var(--c-success); animation: pulse 2s var(--ease) infinite;
}
.modal-log .log-console { flex: 1 1 auto; max-height: 200px; }
.modal-log.is-pulse {
  box-shadow: inset 0 0 0 2px var(--c-cta);
}

/* ----- Sub-tabs inside the device modal -------------------------------- */
.modal-tabs {
  display: flex; gap: 2px; border-bottom: 1px solid var(--c-border);
  margin: 4px 0 16px;
  padding: 0;
}
.modal-tab {
  appearance: none; background: none; border: none;
  padding: 9px 14px 10px; font: inherit; font-weight: 500; font-size: 13px;
  color: var(--c-text-2); cursor: pointer;
  border-bottom: 2px solid transparent;
  display: inline-flex; align-items: center; gap: 8px;
  transition: color var(--d-fast) var(--ease), border-color var(--d-fast) var(--ease);
}
.modal-tab:hover { color: var(--c-primary); }
.modal-tab.is-active { color: var(--c-primary); border-bottom-color: var(--c-cta); font-weight: 600; }
.modal-tab .chip { padding: 1px 8px; font-size: 10.5px; }
.modal-panel { display: none; }
.modal-panel.is-active { display: block; }

/* Windows update row layout (simpler than winget — no version columns) */
.wu-list { display: flex; flex-direction: column; gap: 8px; }
.wu {
  display: grid; grid-template-columns: auto 1fr auto auto;
  gap: 12px; align-items: center;
  padding: 10px 14px; border: 1px solid var(--c-border); border-radius: var(--r-md);
  background: var(--c-surface); font-size: 13px;
  transition: background var(--d-fast) var(--ease), border-color var(--d-fast) var(--ease);
}
.wu:hover { background: #F8FAFC; border-color: var(--c-border-2); }
.wu.is-running { background: #EFF6FF; border-color: #BFDBFE; }
.wu-title { font-weight: 600; color: var(--c-primary); }
.wu-meta { font-size: 11px; color: var(--c-muted); margin-top: 2px; }
.wu-severity { font-size: 10.5px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; }
.wu-severity.critical  { color: var(--c-danger); }
.wu-severity.important { color: var(--c-warning); }
.wu-severity.moderate, .wu-severity.low { color: var(--c-muted); }
.wu-kb {
  font-family: ui-monospace, monospace; font-size: 11px;
  color: var(--c-text-2); background: var(--c-bg);
  padding: 1px 6px; border-radius: 4px; border: 1px solid var(--c-border);
}

/* Key-value list */
.kv { display: grid; grid-template-columns: 140px 1fr; gap: 6px 16px; font-size: 13px; }
.kv dt { color: var(--c-muted); font-weight: 500; }
.kv dd { color: var(--c-text); font-family: ui-monospace, monospace; font-size: 12px; word-break: break-all; }

/* Empty state */
.empty {
  text-align: center; padding: 56px 24px; color: var(--c-muted);
  display: flex; flex-direction: column; align-items: center; gap: 12px;
}
.empty svg { width: 36px; height: 36px; opacity: .5; }
.empty .empty-title { font-weight: 600; color: var(--c-primary); font-size: 14px; }

/* Responsive */
@media (max-width: 1024px) {
  .stats { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 640px) {
  .wrap { padding: 20px 14px 60px; }
  .topbar-inner { padding: 12px 14px; }
  .stats { grid-template-columns: 1fr; }
  .tbl th, .tbl td { padding: 10px 12px; }
  .modal { max-height: 94vh; }
}

/* Banner */
.banner {
  padding: 14px 18px; border-radius: var(--r-md);
  font-size: 13px; margin-bottom: 18px;
  border: 1px solid var(--c-border);
  display: flex; align-items: flex-start; gap: 12px;
}
.banner.is-err { background: var(--c-danger-bg); border-color: #FECACA; color: var(--c-danger); }
.banner.is-info { background: var(--c-info-bg); border-color: #BFDBFE; color: var(--c-info); }
.banner svg { width: 18px; height: 18px; margin-top: 1px; flex-shrink: 0; }

</style>
</head>
<body>

<header class="topbar">
  <div class="topbar-inner">
    <div class="brand">
      <span class="brand-mark" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/></svg>
      </span>
      <div>
        <div class="brand-name">Corrivex</div>
      </div>
      <span class="brand-tag">Enterprise</span>
    </div>
    <div class="topbar-right">
      <span class="ws-status is-down" id="ws-status" title="Live updates">
        <span class="ws-dot"></span><span class="ws-label">connecting…</span>
      </span>
      <span class="badge-secure" title="Authenticated session">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Secure session
      </span>
      <div class="user-menu">
        <button class="user-btn" id="user-btn" aria-haspopup="true" aria-expanded="false">
          <span class="user-avatar">{{printf "%.1s" .CurrentUser.username}}</span>
          <span class="user-meta"><span class="user-name">{{.CurrentUser.username}}</span><span class="user-role">{{.CurrentUser.role}}</span></span>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px;color:var(--c-muted)"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="user-pop" id="user-pop" role="menu">
          <button class="user-item" id="open-profile">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            Profile &amp; 2FA
          </button>
          <button class="user-item" id="logout-btn">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
            Sign out
          </button>
        </div>
      </div>
      <span class="mono" style="font-size:12px;color:var(--c-muted)" title="Corrivex application version">v{{.AppVersion}}</span>
      <span class="mono" style="font-size:11px;color:var(--c-muted);opacity:.7" title="Database schema migration version">schema v{{.SchemaVersion}}</span>
    </div>
  </div>
</header>

<main class="wrap">

  {{if .MigrationError}}
  <div class="banner is-err" role="alert">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
    <div><strong>Database migration failed.</strong><div class="mono" style="margin-top:4px;font-size:12px">{{.MigrationError}}</div></div>
  </div>
  {{end}}

  <!-- Stats -->
  <section class="stats">
    <div class="stat is-total">
      <div class="stat-label"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>Managed devices</div>
      <div class="stat-value">{{.Stats.Total}}</div>
      <div class="stat-hint">All hosts that have reported</div>
    </div>
    <div class="stat is-updates">
      <div class="stat-label"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>Pending updates<span class="pulse"></span></div>
      <div class="stat-value">{{.Stats.WithUpdates}}</div>
      <div class="stat-hint">Devices awaiting patch delivery</div>
    </div>
    <div class="stat is-ok">
      <div class="stat-label"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>Fully patched</div>
      <div class="stat-value">{{.Stats.UpToDate}}</div>
      <div class="stat-hint">No outstanding upgrades</div>
    </div>
    <div class="stat is-new">
      <div class="stat-label"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>Awaiting first scan</div>
      <div class="stat-value">{{.Stats.NeverSeen}}</div>
      <div class="stat-hint">Enrolled, no full report yet</div>
    </div>
  </section>

  <!-- Tabs -->
  <nav class="tabs" role="tablist" aria-label="Dashboard sections">
    <button class="tab is-active" data-tab="devices" role="tab" aria-selected="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>
      Devices
    </button>
    <button class="tab" data-tab="domains" role="tab" aria-selected="false">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10Z"/><path d="M2 12h20"/></svg>
      Allowed domains
    </button>
    <button class="tab" data-tab="settings" role="tab" aria-selected="false">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
      Settings
    </button>
    <button class="tab" data-tab="enroll" role="tab" aria-selected="false">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
      Enroll device
    </button>
    <button class="tab" data-tab="users" role="tab" aria-selected="false" data-admin-only>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      Users
    </button>
  </nav>

  <!-- Devices panel -->
  <section class="tab-panel is-active" id="panel-devices" role="tabpanel">
    <div class="toolbar">
      <div class="toolbar-left">
        <input type="search" class="input" id="device-search" placeholder="Search hostname, domain, OS" aria-label="Search devices">
        <select class="input" id="domain-filter" aria-label="Filter by domain" style="min-width:180px">
          <option value="">All domains</option>
          {{range .Domains}}<option value="{{.Domain}}">{{.Domain}}</option>{{end}}
        </select>
        <select class="input" id="state-filter" aria-label="Filter by state" style="min-width:170px">
          <option value="">All states</option>
          <option value="online">Online (&lt; 24h)</option>
          <option value="stale">Stale (&gt; 3d)</option>
          <option value="never">Never seen</option>
        </select>
      </div>
      <div class="toolbar-right">
        <button class="btn" onclick="location.reload()">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>
          Refresh
        </button>
      </div>
    </div>

    <div class="card">
      <div class="tbl-wrap">
        <table class="tbl" id="device-table">
          <thead>
            <tr>
              <th>Host</th>
              <th>Domain</th>
              <th>OS</th>
              <th>Last seen</th>
              <th>Updates</th>
              <th>Status</th>
              <th style="text-align:right">Actions</th>
            </tr>
          </thead>
          <tbody>
            {{if .PCs}}
            {{range .PCs}}
            <tr class="is-clickable" data-host="{{.Hostname}}" data-search="{{.Hostname}} {{if .Domain}}{{.Domain}}{{end}} {{if .OSVersion}}{{.OSVersion}}{{end}}" data-domain="{{if .Domain}}{{.Domain}}{{end}}" data-online="{{if .Online}}1{{else}}0{{end}}">
              <td>
                <div style="display:flex;align-items:center;gap:8px"><span class="hostname">{{.Hostname}}</span>{{if .Online}}<span class="chip online" data-host-online><span class="dot"></span>online</span>{{else}}<span class="chip offline" data-host-online><span class="dot"></span>offline</span>{{end}}</div>
                {{if .CheckUser}}<div class="sub">{{.CheckUser}}</div>{{end}}
              </td>
              <td>{{if .Domain}}<span class="chip muted">{{.Domain}}</span>{{else}}<span class="chip muted">—</span>{{end}}</td>
              <td class="sub os-cell">{{if .OSVersion}}{{.OSVersion}}{{else}}—{{end}}</td>
              <td class="sub" data-since="{{if .LastSeen}}{{.LastSeen.Format "2006-01-02T15:04:05Z07:00"}}{{end}}">{{if .LastSeen}}{{.LastSeen.Format "2006-01-02 15:04"}}{{else}}Never{{end}}</td>
              <td>
                <div class="upd-stack">
                  {{$wc := .UpdateCount}}
                  {{if lt $wc 0}}<span class="chip upd-unknown" title="No winget scan yet"><span class="src">winget</span>?</span>
                  {{else if eq $wc 0}}<span class="chip upd-clean" title="No winget upgrades available"><span class="src">winget</span>0</span>
                  {{else}}<span class="chip upd-pending" title="Winget upgrades available"><span class="src">winget</span>{{$wc}}</span>{{end}}
                  {{$uc := .WindowsUpdateCount}}
                  {{if lt $uc 0}}<span class="chip upd-unknown" title="No Windows Update scan yet"><span class="src">WU</span>?</span>
                  {{else if eq $uc 0}}<span class="chip upd-clean" title="Windows is up to date"><span class="src">WU</span>0</span>
                  {{else}}<span class="chip upd-pending" title="Windows updates pending"><span class="src">WU</span>{{$uc}}</span>{{end}}
                </div>
              </td>
              <td>{{template "statusChip" .}}</td>
              <td>
                <div class="row-actions">
                  <button class="btn btn-sm" data-action="view" data-host="{{.Hostname}}" title="Open details">Details</button>
                  <button class="btn btn-sm btn-primary" data-action="upgrade-all" data-host="{{.Hostname}}" title="Queue upgrade-all">Upgrade all</button>
                </div>
              </td>
            </tr>
            {{end}}
            {{else}}
            <tr><td colspan="7">
              <div class="empty">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>
                <div class="empty-title">No devices enrolled yet</div>
                <div>Use the <strong>Enroll device</strong> tab to get the bootstrap command.</div>
              </div>
            </td></tr>
            {{end}}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Domains panel -->
  <section class="tab-panel" id="panel-domains" role="tabpanel">
    <div class="toolbar">
      <div class="toolbar-left">
        <h2 class="h2">Allowed domains</h2>
      </div>
      <div class="toolbar-right">
        <input type="text" class="input" id="new-domain" placeholder="contoso.local" aria-label="New domain">
        <input type="text" class="input" id="new-domain-notes" placeholder="Notes (optional)" aria-label="Notes" style="min-width:200px">
        <button class="btn btn-primary" id="add-domain-btn">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
          Add domain
        </button>
      </div>
    </div>
    <div class="card">
      <div class="tbl-wrap">
        <table class="tbl" id="domains-table">
          <thead><tr><th>Domain</th><th>Notes</th><th>Added</th><th style="text-align:right">Action</th></tr></thead>
          <tbody>
          {{range .Domains}}
            <tr data-domain-id="{{.ID}}">
              <td><strong>{{.Domain}}</strong></td>
              <td class="sub">{{if .Notes}}{{.Notes}}{{else}}—{{end}}</td>
              <td class="sub">{{.CreatedAt.Format "2006-01-02"}}</td>
              <td style="text-align:right">
                <button class="btn btn-sm btn-danger" data-action="remove-domain" data-id="{{.ID}}">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6"/><path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                  Remove
                </button>
              </td>
            </tr>
          {{else}}
            <tr><td colspan="4"><div class="empty"><div class="empty-title">No allowed domains configured</div><div>Add your AD domain to enroll devices.</div></div></td></tr>
          {{end}}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Settings panel -->
  <section class="tab-panel" id="panel-settings" role="tabpanel">
    <div class="card" style="max-width:720px">
      <div class="card-hd">
        <div>
          <h2 class="h2">Agent policy</h2>
          <div class="sub" style="color:var(--c-muted);font-size:12px;margin-top:4px">Controls how often devices poll the server and run full scans.</div>
        </div>
      </div>
      <div class="card-bd">
        <div class="field">
          <label for="s-check">Task poll interval (minutes)</label>
          <input type="number" min="1" id="s-check" value="{{.Settings.check_interval_minutes}}">
          <div class="hint">How often the service checks in for pending tasks.</div>
        </div>
        <div class="field">
          <label for="s-scan">Full scan interval (hours)</label>
          <input type="number" min="1" id="s-scan" value="{{.Settings.full_scan_interval_hours}}">
          <div class="hint">How often the service performs a full inventory and upgrade-check.</div>
        </div>
        <div class="field">
          <label for="s-svc">Windows service name</label>
          <input type="text" id="s-svc" value="{{.Settings.service_name}}">
          <div class="hint">Shown in services.msc on managed devices.</div>
