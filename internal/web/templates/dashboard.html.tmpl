// ---- Remove device (uninstall + drop from DB) ----------------------------
document.getElementById('remove-device-btn')?.addEventListener('click', async (e) => {
  const host = e.currentTarget.dataset.host;
  if (!host) return;
  const confirmed = confirm(
    'This will tell ' + host + ' to uninstall the Corrivex agent, ' +
    'stop its service, and delete C:\\ProgramData\\Corrivex.\n\n' +
    'Once the agent confirms, the device is also removed from the server.\n\nContinue?'
  );
  if (!confirmed) return;
  try {
    const res = await fetch(API + '?action=remove_device', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ hostname: host }),
    });
    const json = await res.json();
    if (!res.ok || json.error) throw new Error(json.error || 'HTTP ' + res.status);
    toast('Uninstall queued — waiting for ' + host + ' to report back', 'ok');
    closeModal();
  } catch (err) { toast(err.message, 'err'); }
});

// ---- Copy bootstrap -------------------------------------------------------
async function copyText(text) {
  // Modern Clipboard API: only available in secure contexts (HTTPS or localhost).
  if (window.isSecureContext && navigator.clipboard && navigator.clipboard.writeText) {
    try { await navigator.clipboard.writeText(text); return true; } catch { /* fall through */ }
  }
  // Legacy fallback: hidden textarea + execCommand('copy'). Works on plain HTTP.
  const ta = document.createElement('textarea');
  ta.value = text;
  ta.setAttribute('readonly', '');
  ta.style.position = 'fixed';
  ta.style.top = '0';
  ta.style.left = '0';
  ta.style.opacity = '0';
  document.body.appendChild(ta);
  ta.focus();
  ta.select();
  ta.setSelectionRange(0, ta.value.length);
  let ok = false;
  try { ok = document.execCommand('copy'); } catch { ok = false; }
  document.body.removeChild(ta);
  return ok;
}

document.getElementById('copy-bootstrap-btn')?.addEventListener('click', async () => {
  const text = document.getElementById('bootstrap-cmd').textContent.trim();
  const ok = await copyText(text);
  if (ok) toast('Command copied to clipboard', 'ok');
  else    toast('Copy failed — select the command and copy manually', 'warn');
});
